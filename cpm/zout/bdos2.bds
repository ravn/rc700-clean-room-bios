bb17 bb17 s 	endmerge:
bb17 bb17 d 3eff
bb17 bb17 u 02 01
bb17 bb17 s 		mvi a,true!
bb19 bb19 d 32d2bf
bb19 bb19 u 03 01
bb19 bb19 s  sta fcb$copied ;mark as copied
bb1c bb1c d c310ba
bb1c bb1c u 03 01
bb1c bb1c s 		jmp seek$copy ;ok to "wrdir" here - 1.4 compat
bb1f bb1f s 	;		ret				;
bb1f bb1f s 	mergerr:
bb1f bb1f s 		;elements did not merge correctly
bb1f bb1f d 2145b5
bb1f bb1f u 03 01
bb1f bb1f s 		lxi h,lret!
bb22 bb22 d 35
bb22 bb22 u 01 01
bb22 bb22 s  dcr m ;=255 non zero flag set
bb23 bb23 d c9
bb23 bb23 u 01 01
bb23 bb23 s 	ret
bb24 bb24 s ;
bb24 bb24 s make:
bb24 bb24 s 	;create a new file by creating a directory entry
bb24 bb24 s 	;then opening the file
bb24 bb24 d cd54b7
bb24 bb24 u 03 01
bb24 bb24 s 	call check$write ;may be write protected
bb27 bb27 d 2a43b5
bb27 bb27 u 03 01
bb27 bb27 s 	lhld info!
bb2a bb2a d e5
bb2a bb2a u 01 01
bb2a bb2a s  push h ;save fcb address, look for e5
bb2b bb2b d 21acbf
bb2b bb2b u 03 01
bb2b bb2b s 	lxi h,efcb!
bb2e bb2e d 2243b5
bb2e bb2e u 03 01
bb2e bb2e s  shld info ;info = .empty
bb31 bb31 d 0e01
bb31 bb31 u 02 01
bb31 bb31 s 	mvi c,1!
bb33 bb33 d cd18b9
bb33 bb33 u 03 01
bb33 bb33 s  call search ;length 1 match on empty entry
bb36 bb36 d cdf5b7
bb36 bb36 u 03 01
bb36 bb36 s 	call end$of$dir ;zero flag set if no space
bb39 bb39 d e1
bb39 bb39 u 01 01
bb39 bb39 s 	pop h ;recall info address
bb3a bb3a d 2243b5
bb3a bb3a u 03 01
bb3a bb3a s 	shld info ;in case we return here
bb3d bb3d d c8
bb3d bb3d u 01 01
bb3d bb3d s 	rz ;return with error condition 255 if not found
bb3e bb3e d eb
bb3e bb3e u 01 01
bb3e bb3e s 	xchg ;DE = info address
bb3f bb3f s 	;clear the remainder of the fcb
bb3f bb3f d 210f00
bb3f bb3f u 03 01
bb3f bb3f s 	lxi h,namlen!
bb42 bb42 d 19
bb42 bb42 u 01 01
bb42 bb42 s  dad d ;HL=.fcb(namlen)
bb43 bb43 d 0e11
bb43 bb43 u 02 01
bb43 bb43 s 	mvi c,fcblen-namlen ;number of bytes to fill
bb45 bb45 d af
bb45 bb45 u 01 01
