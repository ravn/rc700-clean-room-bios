b5d1 b5d1 s 	;  jmp seek				;
b5d1 b5d1 s 	;ret
b5d1 b5d1 s ;
b5d1 b5d1 s ;
b5d1 b5d1 s seek:
b5d1 b5d1 s 	;seek the track given by arecord (actual record)
b5d1 b5d1 s 	;local equates for registers
