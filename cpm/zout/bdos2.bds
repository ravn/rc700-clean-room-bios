b8eb b8eb s 		;same user code, check for '$' submit
b8eb b8eb d 23
b8eb b8eb u 01 01
b8eb b8eb s 		inx h!
b8ec b8ec d 7e
b8ec b8ec u 01 01
b8ec b8ec s  mov a,m ;first character
b8ed b8ed d d624
b8ed b8ed u 02 01
b8ed b8ed s 		sui '$' ;dollar file?
b8ef b8ef d c2f6b8
