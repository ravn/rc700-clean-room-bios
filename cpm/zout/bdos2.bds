bfd5 bfd5 s seqio:	ds	byte	;1 if sequential i/o
bfd6 bfd6 s linfo:	ds	byte	;low(info)
bfd7 bfd7 s dminx:	ds	byte	;local for diskwrite
bfd8 bfd8 s searchl:ds	byte	;search length
bfd9 bfd9 s searcha:ds	word	;search address
bfdb bfdb s tinfo:	ds	word	;temp for info in "make"
