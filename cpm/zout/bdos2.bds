b5da b5da s  mov crecl,m!
b5db b5db d 23
b5db b5db u 01 01
b5db b5db s  inx h!
b5dc b5dc d 56
b5dc b5dc u 01 01
b5dc b5dc s  mov crech,m
b5dd b5dd d 2ab5bf
b5dd b5dd u 03 01
b5dd b5dd s 	lhld curtrka !
b5e0 b5e0 d 7e
b5e0 b5e0 u 01 01
b5e0 b5e0 s  mov a,m!
b5e1 b5e1 d 23
b5e1 b5e1 u 01 01
b5e1 b5e1 s  inx h!
b5e2 b5e2 d 66
b5e2 b5e2 u 01 01
b5e2 b5e2 s  mov ctrkh,m!
b5e3 b5e3 d 6f
b5e3 b5e3 u 01 01
b5e3 b5e3 s  mov ctrkl,a
b5e4 b5e4 s 	;loop while arecord < currec
