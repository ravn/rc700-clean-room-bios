b72c b72c s ;
b72c b72c s set$ro:
b72c b72c s 	;set current disk to read only
b72c b72c d 21adbf
b72c b72c u 03 01
b72c b72c s 	lxi h,rodsk!
b72f b72f d 4e
b72f b72f u 01 01
b72f b72f s  mov c,m!
b730 b730 d 23
b730 b730 u 01 01
b730 b730 s  inx h!
b731 b731 d 46
b731 b731 u 01 01
b731 b731 s  mov b,m
b732 b732 d cd0bb7
b732 b732 u 03 01
b732 b732 s 	call set$cdisk ;sets bit to 1
b735 b735 d 22adbf
b735 b735 u 03 01
b735 b735 s 	shld rodsk
b738 b738 s 	;high water mark in directory goes to max
b738 b738 d 2ac8bf
b738 b738 u 03 01
b738 b738 s 	lhld dirmax!
b73b b73b d 23
b73b b73b u 01 01
b73b b73b s  inx h!
b73c b73c d eb
b73c b73c u 01 01
b73c b73c s  xchg ;DE = directory max	
b73d b73d d 2ab3bf
b73d b73d u 03 01
b73d b73d s 	lhld cdrmaxa ;HL = .cdrmax
b740 b740 d 73
b740 b740 u 01 01
b740 b740 s 	mov m,e!
b741 b741 d 23
b741 b741 u 01 01
b741 b741 s  inx h!
b742 b742 d 72
b742 b742 u 01 01
b742 b742 s  mov m,d ;cdrmax = dirmax
b743 b743 d c9
b743 b743 u 01 01
b743 b743 s 	ret
b744 b744 s ;
