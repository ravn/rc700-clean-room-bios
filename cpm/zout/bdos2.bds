b8e4 b8e4 s 		;not empty, user code the same?
b8e4 b8e4 d 3a41b5
b8e4 b8e4 u 03 01
b8e4 b8e4 s 		lda usrcode
b8e7 b8e7 d be
b8e7 b8e7 u 01 01
b8e7 b8e7 s 		cmp m!
b8e8 b8e8 d c2f6b8
b8e8 b8e8 u 03 01
