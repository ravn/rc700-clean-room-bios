b85c b85c s setallocbit:
b85c b85c s 	;BC is the bit position of ALLOC to set or reset.  The
b85c b85c s 	;value of the bit is in register E.
b85c b85c d d5
b85c b85c u 01 01
b85c b85c s 	push d!
b85d b85d d cd35b8
b85d b85d u 03 01
b85d b85d s  call getallocbit ;shifted val A, count in D
b860 b860 d e6fe
b860 b860 u 02 01
b860 b860 s 	ani 1111$1110b ;mask low bit to zero (may be set)
b862 b862 d c1
b862 b862 u 01 01
b862 b862 s 	pop b!
b863 b863 d b1
b863 b863 u 01 01
b863 b863 s  ora c ;low bit of C is masked into A
b864 b864 s ;	jmp rotr ;to rotate back into proper position	
b864 b864 s 	;ret
b864 b864 s rotr:
b864 b864 s 	;byte value from ALLOC is in register A, with shift count
b864 b864 s 	;in register C (to place bit back into position), and
b864 b864 s 	;target ALLOC position in registers HL, rotate and replace
b864 b864 d 0f
b864 b864 u 01 01
b864 b864 s 	rrc!
b865 b865 d 15
b865 b865 u 01 01
b865 b865 s  dcr d!
b866 b866 d c264b8
b866 b866 u 03 01
b866 b866 s  jnz rotr ;back into position
b869 b869 d 77
b869 b869 u 01 01
b869 b869 s 	mov m,a ;back to ALLOC
b86a b86a d c9
b86a b86a u 01 01
b86a b86a s 	ret
b86b b86b s ;
b86b b86b s scandm:
b86b b86b s 	;scan the disk map addressed by dptr for non-zero
b86b b86b s 	;entries, the allocation vector entry corresponding
b86b b86b s 	;to a non-zero entry is set to the value of C (0,1)
b86b b86b d cd5eb7
b86b b86b u 03 01
b86b b86b s 	call getdptra ;HL = buffa + dptr
b86e b86e s 	;HL addresses the beginning of the directory entry
b86e b86e d 111000
b86e b86e u 03 01
b86e b86e s 	lxi d,dskmap!
b871 b871 d 19
b871 b871 u 01 01
