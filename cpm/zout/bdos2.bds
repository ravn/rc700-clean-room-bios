b850 b850 u 01 01
b850 b850 s  mov b,a ;BC shr 3 to BC
b851 b851 d 2abfbf
b851 b851 u 03 01
b851 b851 s 	lhld alloca ;base address of allocation vector
b854 b854 d 09
b854 b854 u 01 01
b854 b854 s 	dad b!
b855 b855 d 7e
b855 b855 u 01 01
b855 b855 s  mov a,m ;byte to A, hl = .alloc(BC shr 3)
b856 b856 s 	;now move the bit to the low order position of A
b856 b856 d 07
b856 b856 u 01 01
b856 b856 s 	rotl: rlc!
b857 b857 d 1d
b857 b857 u 01 01
b857 b857 s  dcr e!
b858 b858 d c256b8
b858 b858 u 03 01
b858 b858 s  jnz rotl!
b85b b85b d c9
b85b b85b u 01 01
