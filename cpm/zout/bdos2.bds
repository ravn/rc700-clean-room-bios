binary-debuggable-source
0000 0000 f bdos2.asm
0000 0000 s 	title	'Bdos Interface, Bdos, Version 2.2 Feb, 1980'
0000 0000 s ;*****************************************************************
0000 0000 s ;*****************************************************************
0000 0000 s ;**                                                             **
0000 0000 s ;**   B a s i c    D i s k   O p e r a t i n g   S y s t e m    **
0000 0000 s ;**            I n t e r f a c e   M o d u l e                   **
0000 0000 s ;**                                                             **
0000 0000 s ;*****************************************************************
0000 0000 s ;*****************************************************************
0000 0000 s ;
0000 0000 s ;	Copyright (c) 1978, 1979, 1980
0000 0000 s ;	Digital Research
0000 0000 s ;	Box 579, Pacific Grove
0000 0000 s ;	California
0000 0000 s ;
0000 0000 s ;
0000 0000 s ;      20 january 1980
0000 0000 s ;
0000 0000 s ;	Modifications by Michael Ringgaard, October 2015:
0000 0000 s ;	 - origin changed from 0800h to 0cc00h
0000 0000 s ;
0000 0000 s on	equ	0ffffh
0000 0000 s off	equ	00000h
0000 0000 s test	equ	off
0000 0000 s ;
0000 0000 s 	if	test
0000 0000 s 	org	0dc00h
0000 0000 s 	else
b200 b200 s 	org	0b200h
b200 b200 s 	endif
b200 b200 s ;	bios value defined at end of module
b200 b200 s ;
b200 b200 s ssize	equ	24		;24 level stack
b200 b200 s ;
b200 b200 s ;	low memory locations
b200 b200 s reboot	equ	0000h		;reboot system
b200 b200 s ioloc	equ	0003h		;i/o byte location
b200 b200 s bdosa	equ	0006h		;address field of jmp BDOS
b200 b200 s ;
b200 b200 s ;	bios access constants
b200 b200 s bootf	set	bios+3*0	;cold boot function
b200 b200 s wbootf	set	bios+3*1	;warm boot function
b200 b200 s constf	set	bios+3*2	;console status function
b200 b200 s coninf	set	bios+3*3	;console input function
b200 b200 s conoutf	set	bios+3*4	;console output function
b200 b200 s listf	set	bios+3*5	;list output function
b200 b200 s punchf	set	bios+3*6	;punch output function
b200 b200 s readerf	set	bios+3*7	;reader input function
b200 b200 s homef	set	bios+3*8	;disk home function
b200 b200 s seldskf	set	bios+3*9	;select disk function
b200 b200 s settrkf	set	bios+3*10	;set track function
b200 b200 s setsecf	set	bios+3*11	;set sector function
b200 b200 s setdmaf	set	bios+3*12	;set dma function
b200 b200 s readf	set	bios+3*13	;read disk function
b200 b200 s writef	set	bios+3*14	;write disk function
b200 b200 s liststf	set	bios+3*15	;list status function
b200 b200 s sectran	set	bios+3*16	;sector translate
b200 b200 s ;
b200 b200 s ;	equates for non graphic characters
b200 b200 s ctlc	equ	03h	;control c
b200 b200 s ctle	equ	05h	;physical eol
b200 b200 s ctlh	equ	08h	;backspace
b200 b200 s ctlp	equ	10h	;prnt toggle
b200 b200 s ctlr	equ	12h	;repeat line
b200 b200 s ctls	equ	13h	;stop/start screen
b200 b200 s ctlu	equ	15h	;line delete
b200 b200 s ctlx	equ	18h	;=ctl-u
b200 b200 s ctlz	equ	1ah	;end of file
b200 b200 s rubout	equ	7fh	;char delete
b200 b200 s tab	equ	09h	;tab char
b200 b200 s cr	equ	0dh	;carriage return
b200 b200 s lf	equ	0ah	;line feed
b200 b200 s ctl	equ	5eh	;up arrow
b200 b200 s ;
b200 b200 d 000000000000
b200 b200 u 06 02
b200 b200 s 	db	0,0,0,0,0,0
b206 b206 s ;
b206 b206 s ;	enter here from the user's program with function number in c,
b206 b206 s ;	and information address in d,e
b206 b206 d c311b2
b206 b206 u 03 01
b206 b206 s 	jmp	bdose	;past parameter block
b209 b209 s ;
b209 b209 s ;	************************************************
b209 b209 s ;	*** relative locations 0009 - 000e           ***
b209 b209 s ;	************************************************
b209 b209 d 99b2
b209 b209 u 02 02
b209 b209 s pererr:	dw	persub	;permanent error subroutine
b20b b20b d a5b2
b20b b20b u 02 02
b20b b20b s selerr:	dw	selsub	;select error subroutine
b20d b20d d abb2
b20d b20d u 02 02
b20d b20d s roderr:	dw	rodsub	;ro disk error subroutine
b20f b20f d b1b2
b20f b20f u 02 02
b20f b20f s roferr:	dw	rofsub	;ro file error subroutine
b211 b211 s ;
b211 b211 s ;
b211 b211 s bdose:	;arrive here from user programs
b211 b211 d eb
b211 b211 u 01 01
b211 b211 s 	xchg!
b212 b212 d 2243b5
b212 b212 u 03 01
b212 b212 s  shld info!
b215 b215 d eb
b215 b215 u 01 01
b215 b215 s  xchg ;info=DE, DE=info
b216 b216 d 7b
b216 b216 u 01 01
b216 b216 s 	mov a,e!
b217 b217 d 32d6bf
b217 b217 u 03 01
b217 b217 s  sta linfo ;linfo = low(info) - don't equ
b21a b21a d 210000
b21a b21a u 03 01
b21a b21a s 	lxi h,0!
b21d b21d d 2245b5
b21d b21d u 03 01
b21d b21d s  shld aret ;return value defaults to 0000
b220 b220 s 	;save user's stack pointer, set to local stack
b220 b220 d 39
b220 b220 u 01 01
b220 b220 s 	dad sp!
b221 b221 d 220fb5
b221 b221 u 03 01
b221 b221 s  shld entsp ;entsp = stackptr
b224 b224 d 3141b5
b224 b224 u 03 01
b224 b224 s 	lxi sp,lstack ;local stack setup
b227 b227 d af
b227 b227 u 01 01
b227 b227 s 	xra a!
b228 b228 d 32e0bf
b228 b228 u 03 01
b228 b228 s  sta fcbdsk!
b22b b22b d 32debf
b22b b22b u 03 01
b22b b22b s  sta resel ;fcbdsk,resel=false
b22e b22e d 2174bf
b22e b22e u 03 01
b22e b22e s 	lxi h,goback ;return here after all functions
b231 b231 d e5
b231 b231 u 01 01
b231 b231 s 	push h ;jmp goback equivalent to ret
b232 b232 d 79
b232 b232 u 01 01
b232 b232 s 	mov a,c!
b233 b233 d fe29
b233 b233 u 02 01
b233 b233 s  cpi nfuncs!
b235 b235 d d0
b235 b235 u 01 01
b235 b235 s  rnc ;skip if invalid #
b236 b236 d 4b
b236 b236 u 01 01
b236 b236 s 	mov c,e ;possible output character to C
b237 b237 d 2147b2
b237 b237 u 03 01
b237 b237 s 	lxi h,functab!
b23a b23a d 5f
b23a b23a u 01 01
b23a b23a s  mov e,a!
b23b b23b d 1600
b23b b23b u 02 01
b23b b23b s  mvi d,0 ;DE=func, HL=.ciotab
b23d b23d d 19
b23d b23d u 01 01
b23d b23d s 	dad d!
b23e b23e d 19
b23e b23e u 01 01
b23e b23e s  dad d!
b23f b23f d 5e
b23f b23f u 01 01
b23f b23f s  mov e,m!
b240 b240 d 23
b240 b240 u 01 01
b240 b240 s  inx h!
b241 b241 d 56
b241 b241 u 01 01
b241 b241 s  mov d,m ;DE=functab(func)
b242 b242 d 2a43b5
b242 b242 u 03 01
b242 b242 s 		lhld info	;info in DE for later xchg	
b245 b245 d eb
b245 b245 u 01 01
b245 b245 s 	xchg!
b246 b246 d e9
b246 b246 u 01 01
b246 b246 s  pchl ;dispatched
b247 b247 s ;
b247 b247 s ;	dispatch table for functions
b247 b247 s functab:
b247 b247 d 03c0c8b490b3ceb4
b247 b247 u 08 02
b247 b247 s 	dw	wbootf, func1, func2, func3
b24f b24f d 12c00fc0d4b4edb4
b24f b24f u 08 02
b24f b24f s 	dw	punchf, listf, func6, func7
b257 b257 d f3b4f8b4e1b3feb4
b257 b257 u 08 02
b257 b257 s 	dw	func8, func9, func10,func11
b25f b25f s diskf	equ	($-functab)/2	;disk funcs
b25f b25f d 7ebe83be45be9cbe
b25f b25f u 08 02
b25f b25f s 	dw	func12,func13,func14,func15
b267 b267 d a5beabbec8bed7be
b267 b267 u 08 02
b267 b267 s 	dw	func16,func17,func18,func19
b26f b26f d e0bee6beecbef5be
b26f b26f u 08 02
b26f b26f s 	dw	func20,func21,func22,func23
b277 b277 d febe04bf0abf11bf
b277 b277 u 08 02
b277 b277 s 	dw	func24,func25,func26,func27
b27f b27f d 2cb717bf1dbf26bf
b27f b27f u 08 02
b27f b27f s 	dw	func28,func29,func30,func31
b287 b287 d 2dbf41bf47bf4dbf
b287 b287 u 08 02
b287 b287 s 	dw	func32,func33,func34,func35
b28f b28f d 0ebe53bf04b504b5
b28f b28f u 08 02
b28f b28f s 	dw	func36,func37,func38,func39		;
b297 b297 d 9bbf
b297 b297 u 02 02
b297 b297 s 	dw	func40					;
b299 b299 s nfuncs	equ	($-functab)/2
b299 b299 s ;
b299 b299 s ;
b299 b299 s ;	error subroutines
b299 b299 s persub:	;report permanent error
b299 b299 d 21cab2
b299 b299 u 03 01
b299 b299 s 	lxi h,permsg!
b29c b29c d cde5b2
b29c b29c u 03 01
b29c b29c s  call errflg ;to report the error
b29f b29f d fe03
b29f b29f u 02 01
b29f b29f s 	cpi ctlc!
b2a1 b2a1 d ca0000
b2a1 b2a1 u 03 01
b2a1 b2a1 s  jz reboot ;reboot if response is ctlc
b2a4 b2a4 d c9
b2a4 b2a4 u 01 01
b2a4 b2a4 s 	ret ;and ignore the error
b2a5 b2a5 s ;
b2a5 b2a5 s selsub:	;report select error
b2a5 b2a5 d 21d5b2
b2a5 b2a5 u 03 01
b2a5 b2a5 s 	lxi h,selmsg!
b2a8 b2a8 d c3b4b2
b2a8 b2a8 u 03 01
b2a8 b2a8 s  jmp wait$err ;wait console before boot
b2ab b2ab s ;
b2ab b2ab s rodsub:	;report write to read/only disk
b2ab b2ab d 21e1b2
b2ab b2ab u 03 01
b2ab b2ab s 	lxi h,rodmsg!
b2ae b2ae d c3b4b2
b2ae b2ae u 03 01
b2ae b2ae s  jmp wait$err ;wait console
b2b1 b2b1 s ;
b2b1 b2b1 s rofsub:	;report read/only file
b2b1 b2b1 d 21dcb2
b2b1 b2b1 u 03 01
b2b1 b2b1 s 	lxi h,rofmsg ;drop through to wait for console
b2b4 b2b4 s ;
b2b4 b2b4 s wait$err:
b2b4 b2b4 s 	;wait for response before boot
b2b4 b2b4 d cde5b2
b2b4 b2b4 u 03 01
b2b4 b2b4 s 	call errflg!
b2b7 b2b7 d c30000
b2b7 b2b7 u 03 01
b2b7 b2b7 s  jmp reboot
b2ba b2ba s ;
b2ba b2ba s ;	error messages
b2ba b2ba d 42646f7320457272204f6e20
b2ba b2ba u 0c 02
b2ba b2ba s dskmsg:	db	'Bdos Err On '
b2c6 b2c6 d 203a2024
b2c6 b2c6 u 04 02
b2c6 b2c6 s dskerr:	db	' : $'	;filled in by errflg
b2ca b2ca d 42616420536563746f7224
b2ca b2ca u 0b 02
b2ca b2ca s permsg:	db	'Bad Sector$'
b2d5 b2d5 d 53656c65637424
b2d5 b2d5 u 07 02
b2d5 b2d5 s selmsg:	db	'Select$'
b2dc b2dc d 46696c6520
b2dc b2dc u 05 02
b2dc b2dc s rofmsg:	db	'File '
b2e1 b2e1 d 522f4f24
b2e1 b2e1 u 04 02
b2e1 b2e1 s rodmsg:	db	'R/O$'
b2e5 b2e5 s ;
b2e5 b2e5 s ;
b2e5 b2e5 s errflg:
b2e5 b2e5 s 	;report error to console, message address in HL
b2e5 b2e5 d e5
b2e5 b2e5 u 01 01
b2e5 b2e5 s 	push h!
b2e6 b2e6 d cdc9b3
b2e6 b2e6 u 03 01
b2e6 b2e6 s  call crlf ;stack mssg address, new line
b2e9 b2e9 d 3a42b5
b2e9 b2e9 u 03 01
b2e9 b2e9 s 	lda curdsk!
b2ec b2ec d c641
b2ec b2ec u 02 01
b2ec b2ec s  adi 'A'!
b2ee b2ee d 32c6b2
b2ee b2ee u 03 01
b2ee b2ee s  sta dskerr ;current disk name
b2f1 b2f1 d 01bab2
b2f1 b2f1 u 03 01
b2f1 b2f1 s 	lxi b,dskmsg!
b2f4 b2f4 d cdd3b3
b2f4 b2f4 u 03 01
b2f4 b2f4 s  call print ;the error message
b2f7 b2f7 d c1
b2f7 b2f7 u 01 01
b2f7 b2f7 s 	pop b!
b2f8 b2f8 d cdd3b3
b2f8 b2f8 u 03 01
b2f8 b2f8 s  call print ;error mssage tail
b2fb b2fb s 	;jmp conin ;to get the input character			
b2fb b2fb s 	;(drop through to conin)
b2fb b2fb s 	;ret
b2fb b2fb s ;
b2fb b2fb s ;
b2fb b2fb s ;	console handlers
b2fb b2fb s conin:
b2fb b2fb s 	;read console character to A
b2fb b2fb d 210eb5
b2fb b2fb u 03 01
b2fb b2fb s 	lxi h,kbchar!
b2fe b2fe d 7e
b2fe b2fe u 01 01
b2fe b2fe s  mov a,m!
b2ff b2ff d 3600
b2ff b2ff u 02 01
b2ff b2ff s  mvi m,0!
b301 b301 d b7
b301 b301 u 01 01
b301 b301 s  ora a!
b302 b302 d c0
b302 b302 u 01 01
b302 b302 s  rnz
b303 b303 s 	;no previous keyboard character ready
b303 b303 d c309c0
b303 b303 u 03 01
b303 b303 s 	jmp coninf ;get character externally
b306 b306 s 	;ret
b306 b306 s ;
b306 b306 s conech:
b306 b306 s 	;read character with echo
b306 b306 d cdfbb2
b306 b306 u 03 01
b306 b306 s 	call conin!
b309 b309 d cd14b3
b309 b309 u 03 01
b309 b309 s  call echoc!
b30c b30c d d8
b30c b30c u 01 01
b30c b30c s  rc ;echo character?
b30d b30d s         ;character must be echoed before return
b30d b30d d f5
b30d b30d u 01 01
b30d b30d s 	push psw!
b30e b30e d 4f
b30e b30e u 01 01
b30e b30e s  mov c,a!
b30f b30f d cd90b3
b30f b30f u 03 01
b30f b30f s  call tabout!
b312 b312 d f1
b312 b312 u 01 01
b312 b312 s  pop psw
b313 b313 d c9
b313 b313 u 01 01
b313 b313 s 	ret ;with character in A
b314 b314 s ;
b314 b314 s echoc:
b314 b314 s 	;echo character if graphic
b314 b314 s 	;cr, lf, tab, or backspace
b314 b314 d fe0d
b314 b314 u 02 01
b314 b314 s 	cpi cr!
b316 b316 d c8
b316 b316 u 01 01
b316 b316 s  rz ;carriage return?
b317 b317 d fe0a
b317 b317 u 02 01
b317 b317 s 	cpi lf!
b319 b319 d c8
b319 b319 u 01 01
b319 b319 s  rz ;line feed?
b31a b31a d fe09
b31a b31a u 02 01
b31a b31a s 	cpi tab!
b31c b31c d c8
b31c b31c u 01 01
b31c b31c s  rz ;tab?
b31d b31d d fe08
b31d b31d u 02 01
b31d b31d s 	cpi ctlh!
b31f b31f d c8
b31f b31f u 01 01
b31f b31f s  rz ;backspace?
b320 b320 d fe20
b320 b320 u 02 01
b320 b320 s 	cpi ' '!
b322 b322 d c9
b322 b322 u 01 01
b322 b322 s  ret ;carry set if not graphic
b323 b323 s ;
b323 b323 s conbrk:	;check for character ready
b323 b323 d 3a0eb5
b323 b323 u 03 01
b323 b323 s 	lda kbchar!
b326 b326 d b7
b326 b326 u 01 01
b326 b326 s  ora a!
b327 b327 d c245b3
b327 b327 u 03 01
b327 b327 s  jnz conb1 ;skip if active kbchar
b32a b32a s 		;no active kbchar, check external break
b32a b32a d cd06c0
b32a b32a u 03 01
b32a b32a s 		call constf!
b32d b32d d e601
b32d b32d u 02 01
b32d b32d s  ani 1!
b32f b32f d c8
b32f b32f u 01 01
b32f b32f s  rz ;return if no char ready
b330 b330 s 		;character ready, read it
b330 b330 d cd09c0
b330 b330 u 03 01
b330 b330 s 		call coninf ;to A
b333 b333 d fe13
b333 b333 u 02 01
b333 b333 s 		cpi ctls!
b335 b335 d c242b3
b335 b335 u 03 01
b335 b335 s  jnz conb0 ;check stop screen function
b338 b338 s 		;found ctls, read next character
b338 b338 d cd09c0
b338 b338 u 03 01
b338 b338 s 		call coninf ;to A
b33b b33b d fe03
b33b b33b u 02 01
b33b b33b s 		cpi ctlc!
b33d b33d d ca0000
b33d b33d u 03 01
b33d b33d s  jz reboot ;ctlc implies re-boot
b340 b340 s 		;not a reboot, act as if nothing has happened
b340 b340 d af
b340 b340 u 01 01
b340 b340 s 		xra a!
b341 b341 d c9
b341 b341 u 01 01
b341 b341 s  ret ;with zero in accumulator
b342 b342 s 	conb0:
b342 b342 s 		;character in accum, save it
b342 b342 d 320eb5
b342 b342 u 03 01
b342 b342 s 		sta kbchar
b345 b345 s 	conb1:
b345 b345 s 		;return with true set in accumulator
b345 b345 d 3e01
b345 b345 u 02 01
b345 b345 s 		mvi a,1!
b347 b347 d c9
b347 b347 u 01 01
b347 b347 s  ret
b348 b348 s ;
b348 b348 s conout:
b348 b348 s 	;compute character position/write console char from C
b348 b348 s 	;compcol = true if computing column position
b348 b348 d 3a0ab5
b348 b348 u 03 01
b348 b348 s 	lda compcol!
b34b b34b d b7
b34b b34b u 01 01
b34b b34b s  ora a!
b34c b34c d c262b3
b34c b34c u 03 01
b34c b34c s  jnz compout
b34f b34f s 		;write the character, then compute the column
b34f b34f s 		;write console character from C
b34f b34f d c5
b34f b34f u 01 01
b34f b34f s 		push b!
b350 b350 d cd23b3
b350 b350 u 03 01
b350 b350 s  call conbrk ;check for screen stop function
b353 b353 d c1
b353 b353 u 01 01
b353 b353 s 		pop b!
b354 b354 d c5
b354 b354 u 01 01
b354 b354 s  push b ;recall/save character
b355 b355 d cd0cc0
b355 b355 u 03 01
b355 b355 s 		call conoutf ;externally, to console
b358 b358 d c1
b358 b358 u 01 01
b358 b358 s 		pop b!
b359 b359 d c5
b359 b359 u 01 01
b359 b359 s  push b ;recall/save character
b35a b35a s 		;may be copying to the list device
b35a b35a d 3a0db5
b35a b35a u 03 01
b35a b35a s 		lda listcp!
b35d b35d d b7
b35d b35d u 01 01
b35d b35d s  ora a!
b35e b35e d c40fc0
b35e b35e u 03 01
b35e b35e s  cnz listf ;to printer, if so
b361 b361 d c1
b361 b361 u 01 01
b361 b361 s 		pop b ;recall the character
b362 b362 s 	compout:
b362 b362 d 79
b362 b362 u 01 01
b362 b362 s 		mov a,c ;recall the character
b363 b363 s 		;and compute column position
b363 b363 d 210cb5
b363 b363 u 03 01
b363 b363 s 		lxi h,column ;A = char, HL = .column
b366 b366 d fe7f
b366 b366 u 02 01
b366 b366 s 		cpi rubout!
b368 b368 d c8
b368 b368 u 01 01
b368 b368 s  rz ;no column change if nulls
b369 b369 d 34
b369 b369 u 01 01
b369 b369 s 		inr m ;column = column + 1
b36a b36a d fe20
b36a b36a u 02 01
b36a b36a s 		cpi ' '!
b36c b36c d d0
b36c b36c u 01 01
b36c b36c s  rnc ;return if graphic
b36d b36d s 		;not graphic, reset column position
b36d b36d d 35
b36d b36d u 01 01
b36d b36d s 		dcr m ;column = column - 1
b36e b36e d 7e
b36e b36e u 01 01
b36e b36e s 		mov a,m!
b36f b36f d b7
b36f b36f u 01 01
b36f b36f s  ora a!
b370 b370 d c8
b370 b370 u 01 01
b370 b370 s  rz ;return if at zero
b371 b371 s 		;not at zero, may be backspace or end line
b371 b371 d 79
b371 b371 u 01 01
b371 b371 s 		mov a,c ;character back to A
b372 b372 d fe08
b372 b372 u 02 01
b372 b372 s 		cpi ctlh!
b374 b374 d c279b3
b374 b374 u 03 01
b374 b374 s  jnz notbacksp
b377 b377 s 			;backspace character
b377 b377 d 35
b377 b377 u 01 01
b377 b377 s 			dcr m ;column = column - 1
b378 b378 d c9
b378 b378 u 01 01
b378 b378 s 			ret
b379 b379 s 		notbacksp:
b379 b379 s 			;not a backspace character, eol?
b379 b379 d fe0a
b379 b379 u 02 01
b379 b379 s 			cpi lf!
b37b b37b d c0
b37b b37b u 01 01
b37b b37b s  rnz ;return if not
b37c b37c s 			;end of line, column = 0
b37c b37c d 3600
b37c b37c u 02 01
b37c b37c s 			mvi m,0 ;column = 0
b37e b37e d c9
b37e b37e u 01 01
b37e b37e s 		ret
b37f b37f s ;
b37f b37f s ctlout:
