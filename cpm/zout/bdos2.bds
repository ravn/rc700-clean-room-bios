b8c7 b8c7 s         ;cdrmax = 3 (scans at least one directory record)
b8c7 b8c7 d 2ab3bf
b8c7 b8c7 u 03 01
b8c7 b8c7 s 	lhld cdrmaxa!
b8ca b8ca d 3603
b8ca b8ca u 02 01
b8ca b8ca s  mvi m,3!
b8cc b8cc d 23
b8cc b8cc u 01 01
b8cc b8cc s  inx h!
b8cd b8cd d 3600
b8cd b8cd u 02 01
