b58e b58e s 		;now set single/double map mode
b58e b58e d 2ac6bf
b58e b58e u 03 01
b58e b58e s 		lhld maxall ;largest allocation number
b591 b591 d 7c
b591 b591 u 01 01
b591 b591 s 		mov a,h ;00 indicates < 255
b592 b592 d 21ddbf
b592 b592 u 03 01
b592 b592 s 		lxi h,single!
b595 b595 d 36ff
b595 b595 u 02 01
