b8d2 b8d2 s 		mvi c,true!
b8d4 b8d4 d cd05b8
b8d4 b8d4 u 03 01
b8d4 b8d4 s  call read$dir
b8d7 b8d7 d cdf5b7
b8d7 b8d7 u 03 01
b8d7 b8d7 s 		call end$of$dir!
b8da b8da d c8
b8da b8da u 01 01
b8da b8da s  rz ;return if end of directory
b8db b8db s 		;not end of directory, valid entry?
b8db b8db d cd5eb7
b8db b8db u 03 01
b8db b8db s 		call getdptra ;HL = buffa + dptr
b8de b8de d 3ee5
b8de b8de u 02 01
b8de b8de s 		mvi a,empty!
b8e0 b8e0 d be
b8e0 b8e0 u 01 01
b8e0 b8e0 s  cmp m
b8e1 b8e1 d cad2b8
b8e1 b8e1 u 03 01
