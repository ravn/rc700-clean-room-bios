b873 b873 d 0e11
b873 b873 u 02 01
b873 b873 s 	mvi c,fcblen-dskmap+1 ;size of single byte disk map + 1
b875 b875 s 	scandm0:
b875 b875 s 		;loop once for each disk map entry
b875 b875 d d1
b875 b875 u 01 01
b875 b875 s 		pop d ;recall bit parity
b876 b876 d 0d
b876 b876 u 01 01
b876 b876 s 		dcr c!
b877 b877 d c8
b877 b877 u 01 01
b877 b877 s  rz ;all done scanning?
b878 b878 s 		;no, get next entry for scan
b878 b878 d d5
b878 b878 u 01 01
b878 b878 s 		push d ;replace bit parity
b879 b879 d 3addbf
b879 b879 u 03 01
b879 b879 s 		lda single!
b87c b87c d b7
b87c b87c u 01 01
b87c b87c s  ora a!
b87d b87d d ca88b8
b87d b87d u 03 01
b87d b87d s  jz scandm1
b880 b880 s 			;single byte scan operation
b880 b880 d c5
b880 b880 u 01 01
b880 b880 s 			push b ;save counter
b881 b881 d e5
b881 b881 u 01 01
b881 b881 s 			push h ;save map address
b882 b882 d 4e
b882 b882 u 01 01
b882 b882 s 			mov c,m!
b883 b883 d 0600
b883 b883 u 02 01
b883 b883 s  mvi b,0 ;BC=block#
b885 b885 d c38eb8
b885 b885 u 03 01
b885 b885 s 			jmp scandm2
b888 b888 s 		scandm1:
b888 b888 s 			;double byte scan operation
b888 b888 d 0d
b888 b888 u 01 01
b888 b888 s 			dcr c ;count for double byte
b889 b889 d c5
b889 b889 u 01 01
b889 b889 s 			push b ;save counter
b88a b88a d 4e
b88a b88a u 01 01
b88a b88a s 			mov c,m!
b88b b88b d 23
b88b b88b u 01 01
b88b b88b s  inx h!
b88c b88c d 46
b88c b88c u 01 01
b88c b88c s  mov b,m ;BC=block#
b88d b88d d e5
b88d b88d u 01 01
b88d b88d s 			push h ;save map address
b88e b88e s 		scandm2:
b88e b88e s 			;arrive here with BC=block#, E=0/1
b88e b88e d 79
b88e b88e u 01 01
b88e b88e s 			mov a,c!
b88f b88f d b0
b88f b88f u 01 01
b88f b88f s  ora b ;skip if = 0000
b890 b890 d ca9db8
b890 b890 u 03 01
b890 b890 s 			jz scanm3
b893 b893 d 2ac6bf
b893 b893 u 03 01
b893 b893 s 				lhld maxall	;check invalid index
b896 b896 d 7d
b896 b896 u 01 01
b896 b896 s 			mov a,l!
b897 b897 d 91
b897 b897 u 01 01
b897 b897 s  sub c!
b898 b898 d 7c
b898 b898 u 01 01
b898 b898 s  mov a,h!
b899 b899 d 98
b899 b899 u 01 01
b899 b899 s  sbb b	;maxall - block#
b89a b89a d d45cb8
b89a b89a u 03 01
