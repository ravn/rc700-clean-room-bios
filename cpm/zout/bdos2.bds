b9db b9db d 13
b9db b9db u 01 01
b9db b9db s 		inx d!
b9dc b9dc d c5
b9dc b9dc u 01 01
b9dc b9dc s  push b!
b9dd b9dd d d5
b9dd b9dd u 01 01
b9dd b9dd s  push d ;left, right pushed
b9de b9de d 42
b9de b9de u 01 01
b9de b9de s 		mov b,d!
b9df b9df d 4b
b9df b9df u 01 01
b9df b9df s  mov c,e ;ready right for call
b9e0 b9e0 d cd35b8
b9e0 b9e0 u 03 01
b9e0 b9e0 s 		call getallocbit
b9e3 b9e3 d 1f
b9e3 b9e3 u 01 01
b9e3 b9e3 s 		rar!
b9e4 b9e4 d d2ecb9
b9e4 b9e4 u 03 01
b9e4 b9e4 s  jnc retblock ;return block number if zero
b9e7 b9e7 d d1
b9e7 b9e7 u 01 01
b9e7 b9e7 s 		pop d!
b9e8 b9e8 d c1
b9e8 b9e8 u 01 01
b9e8 b9e8 s  pop b ;restore left and right pointers
b9e9 b9e9 d c3c0b9
b9e9 b9e9 u 03 01
b9e9 b9e9 s 		jmp lefttst ;for another attempt
b9ec b9ec s 	retblock:
b9ec b9ec d 17
b9ec b9ec u 01 01
b9ec b9ec s 		ral!
b9ed b9ed d 3c
b9ed b9ed u 01 01
b9ed b9ed s  inr a ;bit back into position and set to 1
b9ee b9ee s 		;d contains the number of shifts required to reposition
b9ee b9ee d cd64b8
b9ee b9ee u 03 01
