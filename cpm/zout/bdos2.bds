b8a3 b8a3 s ;
b8a3 b8a3 s initialize:
b8a3 b8a3 s 	;initialize the current disk
b8a3 b8a3 s 	;lret = false ;set to true if $ file exists
b8a3 b8a3 s 	;compute the length of the allocation vector - 2
b8a3 b8a3 d 2ac6bf
b8a3 b8a3 u 03 01
b8a3 b8a3 s 	lhld maxall!
b8a6 b8a6 d 0e03
b8a6 b8a6 u 02 01
