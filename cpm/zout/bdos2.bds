b9d6 b9d6 d 7a
b9d6 b9d6 u 01 01
b9d6 b9d6 s  mov a,d!
b9d7 b9d7 d 9c
b9d7 b9d7 u 01 01
b9d7 b9d7 s  sbb h ;right=maxall?
b9d8 b9d8 d d2f4b9
b9d8 b9d8 u 03 01
