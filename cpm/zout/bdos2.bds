bacb bacb s 	mvi c,(fcblen-dskmap) ;length of single byte dm
bacd bacd s 	merge0:
bacd bacd d 3addbf
bacd bacd u 03 01
bacd bacd s 		lda single!
bad0 bad0 d b7
bad0 bad0 u 01 01
bad0 bad0 s  ora a!
bad1 bad1 d cae8ba
bad1 bad1 u 03 01
bad1 bad1 s  jz merged ;skip to double
bad4 bad4 s 		;this is a single byte map
bad4 bad4 s 		;if fcb(i) = 0 then fcb(i) = buff(i)
bad4 bad4 s 		;if buff(i) = 0 then buff(i) = fcb(i)
bad4 bad4 s 		;if fcb(i) <> buff(i) then error
bad4 bad4 d 7e
bad4 bad4 u 01 01
bad4 bad4 s 		mov a,m!
bad5 bad5 d b7
bad5 bad5 u 01 01
bad5 bad5 s  ora a!
bad6 bad6 d 1a
bad6 bad6 u 01 01
bad6 bad6 s  ldax d!
bad7 bad7 d c2dbba
bad7 bad7 u 03 01
bad7 bad7 s  jnz fcbnzero
bada bada s 			;fcb(i) = 0
bada bada d 77
bada bada u 01 01
bada bada s 			mov m,a ;fcb(i) = buff(i)
badb badb s 		fcbnzero:
badb badb d b7
badb badb u 01 01
badb badb s 		ora a!
badc badc d c2e1ba
badc badc u 03 01
badc badc s  jnz buffnzero
badf badf s 			;buff(i) = 0
badf badf d 7e
badf badf u 01 01
badf badf s 			mov a,m!
bae0 bae0 d 12
bae0 bae0 u 01 01
bae0 bae0 s  stax d ;buff(i)=fcb(i)
bae1 bae1 s 		buffnzero:
bae1 bae1 d be
bae1 bae1 u 01 01
bae1 bae1 s 		cmp m!
bae2 bae2 d c21fbb
bae2 bae2 u 03 01
bae2 bae2 s  jnz mergerr ;fcb(i) = buff(i)?
bae5 bae5 d c3fdba
bae5 bae5 u 03 01
bae5 bae5 s 		jmp dmset ;if merge ok
bae8 bae8 s 	merged:
bae8 bae8 s 		;this is a double byte merge operation
bae8 bae8 d cd94ba
bae8 bae8 u 03 01
bae8 bae8 s 		call mergezero ;buff = fcb if buff 0000
baeb baeb d eb
baeb baeb u 01 01
baeb baeb s 		xchg!
baec baec d cd94ba
baec baec u 03 01
baec baec s  call mergezero!
baef baef d eb
baef baef u 01 01
baef baef s  xchg ;fcb = buff if fcb 0000
baf0 baf0 s 		;they should be identical at this point
baf0 baf0 d 1a
baf0 baf0 u 01 01
baf0 baf0 s 		ldax d!
baf1 baf1 d be
baf1 baf1 u 01 01
baf1 baf1 s  cmp m!
baf2 baf2 d c21fbb
baf2 baf2 u 03 01
baf2 baf2 s  jnz mergerr ;low same?
baf5 baf5 d 13
baf5 baf5 u 01 01
baf5 baf5 s 		inx d!
baf6 baf6 d 23
baf6 baf6 u 01 01
baf6 baf6 s  inx h ;to high byte
baf7 baf7 d 1a
baf7 baf7 u 01 01
baf7 baf7 s 		ldax d!
baf8 baf8 d be
baf8 baf8 u 01 01
baf8 baf8 s  cmp m!
baf9 baf9 d c21fbb
baf9 baf9 u 03 01
baf9 baf9 s  jnz mergerr ;high same?
bafc bafc s 		;merge operation ok for this pair
bafc bafc d 0d
bafc bafc u 01 01
bafc bafc s 		dcr c ;extra count for double byte
bafd bafd s 	dmset:
bafd bafd d 13
bafd bafd u 01 01
bafd bafd s 		inx d!
bafe bafe d 23
bafe bafe u 01 01
bafe bafe s  inx h ;to next byte position
baff baff d 0d
baff baff u 01 01
baff baff s 		dcr c!
bb00 bb00 d c2cdba
bb00 bb00 u 03 01
bb00 bb00 s  jnz merge0 ;for more
bb03 bb03 s 		;end of disk map merge, check record count
bb03 bb03 s 		;DE = .buff(dptr)+32, HL = .fcb(32)
bb03 bb03 d 01ecff
bb03 bb03 u 03 01
bb03 bb03 s 		lxi b,-(fcblen-extnum)!
bb06 bb06 d 09
bb06 bb06 u 01 01
bb06 bb06 s  dad b!
bb07 bb07 d eb
bb07 bb07 u 01 01
bb07 bb07 s  xchg!
bb08 bb08 d 09
bb08 bb08 u 01 01
bb08 bb08 s  dad b
bb09 bb09 s 		;DE = .fcb(extnum), HL = .buff(dptr+extnum)
bb09 bb09 d 1a
bb09 bb09 u 01 01
bb09 bb09 s 		ldax d ;current user extent number
bb0a bb0a s 		;if fcb(ext) >= buff(fcb) then
bb0a bb0a s 		;buff(ext) := fcb(ext), buff(rec) := fcb(rec)
bb0a bb0a d be
bb0a bb0a u 01 01
bb0a bb0a s 		cmp m!
bb0b bb0b d da17bb
bb0b bb0b u 03 01
bb0b bb0b s  jc endmerge
bb0e bb0e s 		;fcb extent number >= dir extent number
bb0e bb0e d 77
bb0e bb0e u 01 01
bb0e bb0e s 		mov m,a ;buff(ext) = fcb(ext)
bb0f bb0f s 		;update directory record count field
bb0f bb0f d 010300
bb0f bb0f u 03 01
bb0f bb0f s 		lxi b,(reccnt-extnum)!
bb12 bb12 d 09
bb12 bb12 u 01 01
bb12 bb12 s  dad b!
bb13 bb13 d eb
bb13 bb13 u 01 01
bb13 bb13 s  xchg!
bb14 bb14 d 09
bb14 bb14 u 01 01
bb14 bb14 s  dad b
bb15 bb15 s 		;DE=.buff(reccnt), HL=.fcb(reccnt)
bb15 bb15 d 7e
