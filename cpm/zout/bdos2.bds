b761 b761 u 03 01
b761 b761 s  lda dptr			;
b764 b764 s addh:
b764 b764 s 	;HL = HL + A
b764 b764 d 85
b764 b764 u 01 01
b764 b764 s 	add l!
b765 b765 d 6f
b765 b765 u 01 01
b765 b765 s  mov l,a!
b766 b766 d d0
b766 b766 u 01 01
b766 b766 s  rnc
b767 b767 s 	;overflow to H
b767 b767 d 24
b767 b767 u 01 01
b767 b767 s 	inr h!
b768 b768 d c9
b768 b768 u 01 01
b768 b768 s  ret
b769 b769 s ;
b769 b769 s ;
b769 b769 s getmodnum:
b769 b769 s 	;compute the address of the module number 
b769 b769 s 	;bring module number to accumulator
b769 b769 s 	;(high order bit is fwf (file write flag)
b769 b769 d 2a43b5
b769 b769 u 03 01
b769 b769 s 	lhld info!
b76c b76c d 110e00
b76c b76c u 03 01
b76c b76c s  lxi d,modnum!
b76f b76f d 19
b76f b76f u 01 01
b76f b76f s  dad d ;HL=.fcb(modnum)
b770 b770 d 7e
b770 b770 u 01 01
b770 b770 s 	mov a,m!
b771 b771 d c9
b771 b771 u 01 01
b771 b771 s  ret ;A=fcb(modnum)
b772 b772 s ;
b772 b772 s clrmodnum:
b772 b772 s 	;clear the module number field for user open/make
b772 b772 d cd69b7
b772 b772 u 03 01
b772 b772 s 	call getmodnum!
b775 b775 d 3600
b775 b775 u 02 01
b775 b775 s  mvi m,0 ;fcb(modnum)=0
b777 b777 d c9
b777 b777 u 01 01
b777 b777 s 	ret
b778 b778 s ;
b778 b778 s setfwf:
b778 b778 d cd69b7
b778 b778 u 03 01
b778 b778 s 	call getmodnum ;HL=.fcb(modnum), A=fcb(modnum)
b77b b77b s 	;set fwf (file write flag) to "1"
b77b b77b d f680
b77b b77b u 02 01
b77b b77b s 	ori fwfmsk!
b77d b77d d 77
b77d b77d u 01 01
b77d b77d s  mov m,a ;fcb(modnum)=fcb(modnum) or 80h
b77e b77e s 	;also returns non zero in accumulator
b77e b77e d c9
b77e b77e u 01 01
b77e b77e s 	ret
b77f b77f s ;
b77f b77f s ;
b77f b77f s compcdr:
b77f b77f s 	;return cy if cdrmax > dcnt
b77f b77f d 2aeabf
b77f b77f u 03 01
b77f b77f s 	lhld dcnt!
b782 b782 d eb
b782 b782 u 01 01
b782 b782 s  xchg ;DE = directory counter
b783 b783 d 2ab3bf
b783 b783 u 03 01
b783 b783 s 	lhld cdrmaxa ;HL=.cdrmax
b786 b786 d 7b
b786 b786 u 01 01
b786 b786 s 	mov a,e!
b787 b787 d 96
b787 b787 u 01 01
b787 b787 s  sub m ;low(dcnt) - low(cdrmax)
b788 b788 d 23
b788 b788 u 01 01
b788 b788 s 	inx h ;HL = .cdrmax+1
b789 b789 d 7a
b789 b789 u 01 01
b789 b789 s 	mov a,d!
b78a b78a d 9e
b78a b78a u 01 01
b78a b78a s  sbb m ;hig(dcnt) - hig(cdrmax)
b78b b78b s 	;condition dcnt - cdrmax  produces cy if cdrmax>dcnt
b78b b78b d c9
b78b b78b u 01 01
b78b b78b s 	ret
b78c b78c s ;
b78c b78c s setcdr:
b78c b78c s 	;if not (cdrmax > dcnt) then cdrmax = dcnt+1
b78c b78c d cd7fb7
b78c b78c u 03 01
b78c b78c s 	call compcdr
b78f b78f d d8
b78f b78f u 01 01
b78f b78f s 	rc ;return if cdrmax > dcnt
b790 b790 s 	;otherwise, HL = .cdrmax+1, DE = dcnt
b790 b790 d 13
b790 b790 u 01 01
b790 b790 s 	inx d!
b791 b791 d 72
b791 b791 u 01 01
b791 b791 s  mov m,d!
b792 b792 d 2b
b792 b792 u 01 01
b792 b792 s  dcx h!
b793 b793 d 73
b793 b793 u 01 01
b793 b793 s  mov m,e
b794 b794 d c9
b794 b794 u 01 01
b794 b794 s 	ret
b795 b795 s ;
b795 b795 s subdh:
b795 b795 s 	;compute HL = DE - HL
b795 b795 d 7b
b795 b795 u 01 01
b795 b795 s 	mov a,e!
b796 b796 d 95
b796 b796 u 01 01
b796 b796 s  sub l!
b797 b797 d 6f
b797 b797 u 01 01
b797 b797 s  mov l,a!
b798 b798 d 7a
b798 b798 u 01 01
b798 b798 s  mov a,d!
b799 b799 d 9c
b799 b799 u 01 01
b799 b799 s  sbb h!
b79a b79a d 67
b79a b79a u 01 01
b79a b79a s  mov h,a
b79b b79b d c9
b79b b79b u 01 01
b79b b79b s 	ret
b79c b79c s ;
b79c b79c s newchecksum:
b79c b79c d 0eff
b79c b79c u 02 01
b79c b79c s 	mvi c,true ;drop through to compute new checksum
b79e b79e s checksum:
b79e b79e s 	;compute current checksum record and update the
b79e b79e s 	;directory element if C=true, or check for = if not
b79e b79e s 	;drec < chksiz?
b79e b79e d 2aecbf
b79e b79e u 03 01
b79e b79e s 	lhld drec!
b7a1 b7a1 d eb
b7a1 b7a1 u 01 01
b7a1 b7a1 s  xchg!
b7a2 b7a2 d 2accbf
b7a2 b7a2 u 03 01
b7a2 b7a2 s  lhld chksiz!
b7a5 b7a5 d cd95b7
b7a5 b7a5 u 03 01
b7a5 b7a5 s  call subdh ;DE-HL
b7a8 b7a8 d d0
b7a8 b7a8 u 01 01
b7a8 b7a8 s 	rnc ;skip checksum if past checksum vector size
b7a9 b7a9 s 		;drec < chksiz, so continue
b7a9 b7a9 d c5
b7a9 b7a9 u 01 01
b7a9 b7a9 s 		push b ;save init flag
b7aa b7aa d cdf7b6
b7aa b7aa u 03 01
b7aa b7aa s 		call compute$cs ;check sum value to A
b7ad b7ad d 2abdbf
b7ad b7ad u 03 01
b7ad b7ad s 		lhld checka ;address of check sum vector
b7b0 b7b0 d eb
b7b0 b7b0 u 01 01
b7b0 b7b0 s 		xchg
b7b1 b7b1 d 2aecbf
b7b1 b7b1 u 03 01
b7b1 b7b1 s 		lhld drec ;value of drec
b7b4 b7b4 d 19
b7b4 b7b4 u 01 01
b7b4 b7b4 s 		dad d ;HL = .check(drec)
b7b5 b7b5 d c1
b7b5 b7b5 u 01 01
b7b5 b7b5 s 		pop b ;recall true=0ffh or false=00 to C
b7b6 b7b6 d 0c
b7b6 b7b6 u 01 01
b7b6 b7b6 s 		inr c ;0ffh produces zero flag
b7b7 b7b7 d cac4b7
b7b7 b7b7 u 03 01
b7b7 b7b7 s 		jz initial$cs
b7ba b7ba s 			;not initializing, compare
b7ba b7ba d be
b7ba b7ba u 01 01
b7ba b7ba s 			cmp m ;compute$cs=check(drec)?
b7bb b7bb d c8
b7bb b7bb u 01 01
b7bb b7bb s 			rz ;no message if ok
b7bc b7bc s 			;checksum error, are we beyond
b7bc b7bc s 			;the end of the disk?
b7bc b7bc d cd7fb7
b7bc b7bc u 03 01
b7bc b7bc s 			call compcdr
b7bf b7bf d d0
b7bf b7bf u 01 01
b7bf b7bf s 			rnc ;no message if so
b7c0 b7c0 d cd2cb7
b7c0 b7c0 u 03 01
b7c0 b7c0 s 			call set$ro ;read/only disk set
b7c3 b7c3 d c9
b7c3 b7c3 u 01 01
b7c3 b7c3 s 			ret
b7c4 b7c4 s 		initial$cs:
b7c4 b7c4 s 			;initializing the checksum
b7c4 b7c4 d 77
b7c4 b7c4 u 01 01
b7c4 b7c4 s 			mov m,a!
b7c5 b7c5 d c9
b7c5 b7c5 u 01 01
b7c5 b7c5 s  ret
b7c6 b7c6 s ;
b7c6 b7c6 s ;
b7c6 b7c6 s wrdir:
b7c6 b7c6 s 	;write the current directory entry, set checksum
b7c6 b7c6 d cd9cb7
b7c6 b7c6 u 03 01
b7c6 b7c6 s 	call newchecksum ;initialize entry
b7c9 b7c9 d cde0b7
b7c9 b7c9 u 03 01
b7c9 b7c9 s 	call setdir ;directory dma
b7cc b7cc d 0e01
b7cc b7cc u 02 01
b7cc b7cc s 	mvi c,1 ;indicates a write directory operation
b7ce b7ce d cdb8b5
b7ce b7ce u 03 01
b7ce b7ce s 	call wrbuff ;write the buffer
b7d1 b7d1 d c3dab7
b7d1 b7d1 u 03 01
b7d1 b7d1 s         jmp setdata ;to data dma address
b7d4 b7d4 s 	;ret
b7d4 b7d4 s ;
b7d4 b7d4 s rd$dir:
b7d4 b7d4 s 	;read a directory entry into the directory buffer
b7d4 b7d4 d cde0b7
b7d4 b7d4 u 03 01
b7d4 b7d4 s 	call setdir ;directory dma
b7d7 b7d7 d cdb2b5
b7d7 b7d7 u 03 01
b7d7 b7d7 s 	call rdbuff ;directory record loaded
b7da b7da s         ; jmp setdata to data dma address    
b7da b7da s 	;ret
b7da b7da s ;
b7da b7da s setdata:
b7da b7da s 	;set data dma address
b7da b7da d 21b1bf
b7da b7da u 03 01
b7da b7da s 	lxi h,dmaad!
b7dd b7dd d c3e3b7
b7dd b7dd u 03 01
b7dd b7dd s  jmp setdma ;to complete the call
b7e0 b7e0 s ;
b7e0 b7e0 s setdir:
b7e0 b7e0 s 	;set directory dma address
b7e0 b7e0 d 21b9bf
b7e0 b7e0 u 03 01
b7e0 b7e0 s 	lxi h,buffa  ;jmp setdma to complete call     
b7e3 b7e3 s ;
b7e3 b7e3 s setdma:
b7e3 b7e3 s 	;HL=.dma address to set (i.e., buffa or dmaad)
b7e3 b7e3 d 4e
b7e3 b7e3 u 01 01
b7e3 b7e3 s 	mov c,m!
b7e4 b7e4 d 23
b7e4 b7e4 u 01 01
b7e4 b7e4 s  inx h!
b7e5 b7e5 d 46
b7e5 b7e5 u 01 01
b7e5 b7e5 s  mov b,m ;parameter ready
b7e6 b7e6 d c324c0
b7e6 b7e6 u 03 01
b7e6 b7e6 s 	jmp setdmaf
b7e9 b7e9 s ;
b7e9 b7e9 s ;
b7e9 b7e9 s dir$to$user:
b7e9 b7e9 s 	;copy the directory entry to the user buffer
b7e9 b7e9 s 	;after call to search or searchn by user code
b7e9 b7e9 d 2ab9bf
b7e9 b7e9 u 03 01
b7e9 b7e9 s 	lhld buffa!
b7ec b7ec d eb
b7ec b7ec u 01 01
b7ec b7ec s  xchg ;source is directory buffer
b7ed b7ed d 2ab1bf
b7ed b7ed u 03 01
b7ed b7ed s 	lhld dmaad ;destination is user dma address
b7f0 b7f0 d 0e80
b7f0 b7f0 u 02 01
b7f0 b7f0 s 	mvi c,recsiz ;copy entire record
b7f2 b7f2 d c34fb5
b7f2 b7f2 u 03 01
b7f2 b7f2 s 	jmp move
b7f5 b7f5 s 	;ret
b7f5 b7f5 s ;
b7f5 b7f5 s end$of$dir:
b7f5 b7f5 s 	;return zero flag if at end of directory, non zero
b7f5 b7f5 s 	;if not at end (end of dir if dcnt = 0ffffh)
b7f5 b7f5 d 21eabf
b7f5 b7f5 u 03 01
b7f5 b7f5 s 	lxi h,dcnt!
b7f8 b7f8 d 7e
b7f8 b7f8 u 01 01
b7f8 b7f8 s  mov a,m ;may be 0ffh
b7f9 b7f9 d 23
b7f9 b7f9 u 01 01
b7f9 b7f9 s 	inx h!
b7fa b7fa d be
b7fa b7fa u 01 01
b7fa b7fa s  cmp m ;low(dcnt) = high(dcnt)?
b7fb b7fb d c0
b7fb b7fb u 01 01
b7fb b7fb s 	rnz ;non zero returned if different
b7fc b7fc s 	;high and low the same, = 0ffh?
b7fc b7fc d 3c
b7fc b7fc u 01 01
b7fc b7fc s 	inr a ;0ffh becomes 00 if so
b7fd b7fd d c9
b7fd b7fd u 01 01
b7fd b7fd s 	ret
b7fe b7fe s ;
b7fe b7fe s set$end$dir:
b7fe b7fe s 	;set dcnt to the end of the directory
b7fe b7fe d 21ffff
b7fe b7fe u 03 01
b7fe b7fe s 	lxi h,enddir!
b801 b801 d 22eabf
b801 b801 u 03 01
b801 b801 s  shld dcnt!
b804 b804 d c9
b804 b804 u 01 01
b804 b804 s  ret
b805 b805 s ;
b805 b805 s read$dir:
b805 b805 s 	;read next directory entry, with C=true if initializing
b805 b805 d 2ac8bf
b805 b805 u 03 01
b805 b805 s 	lhld dirmax!
b808 b808 d eb
b808 b808 u 01 01
b808 b808 s  xchg ;in preparation for subtract
b809 b809 d 2aeabf
b809 b809 u 03 01
b809 b809 s 	lhld dcnt!
b80c b80c d 23
b80c b80c u 01 01
b80c b80c s  inx h!
b80d b80d d 22eabf
b80d b80d u 03 01
b80d b80d s  shld dcnt ;dcnt=dcnt+1
b810 b810 s 	;continue while dirmax >= dcnt (dirmax-dcnt no cy)
b810 b810 d cd95b7
b810 b810 u 03 01
b810 b810 s 	call subdh ;DE-HL
b813 b813 d d219b8
b813 b813 u 03 01
b813 b813 s 	jnc read$dir0
b816 b816 s 		;yes, set dcnt to end of directory
b816 b816 d c3feb7
b816 b816 u 03 01
b816 b816 s 		jmp set$end$dir			;
b819 b819 s ;		ret				;
b819 b819 s 	read$dir0:
b819 b819 s 		;not at end of directory, seek next element
b819 b819 s 		;initialization flag is in C
b819 b819 d 3aeabf
b819 b819 u 03 01
b819 b819 s 		lda dcnt!
b81c b81c d e603
b81c b81c u 02 01
b81c b81c s  ani dskmsk ;low(dcnt) and dskmsk
b81e b81e d 0605
b81e b81e u 02 01
b81e b81e s 		mvi b,fcbshf ;to multiply by fcb size
b820 b820 s 		read$dir1:
b820 b820 d 87
b820 b820 u 01 01
b820 b820 s 			add a!
b821 b821 d 05
b821 b821 u 01 01
b821 b821 s  dcr b!
b822 b822 d c220b8
b822 b822 u 03 01
b822 b822 s  jnz read$dir1
b825 b825 s 		;A = (low(dcnt) and dskmsk) shl fcbshf
b825 b825 d 32e9bf
b825 b825 u 03 01
b825 b825 s 		sta dptr ;ready for next dir operation
b828 b828 d b7
b828 b828 u 01 01
b828 b828 s 		ora a!
b829 b829 d c0
b829 b829 u 01 01
b829 b829 s  rnz ;return if not a new record
b82a b82a d c5
b82a b82a u 01 01
b82a b82a s 		push b ;save initialization flag C
b82b b82b d cdc3b5
b82b b82b u 03 01
b82b b82b s 		call seek$dir ;seek proper record
b82e b82e d cdd4b7
b82e b82e u 03 01
b82e b82e s 		call rd$dir ;read the directory record
b831 b831 d c1
