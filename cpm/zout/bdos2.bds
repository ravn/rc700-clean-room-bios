bb48 bb48 d 0d
bb48 bb48 u 01 01
bb48 bb48 s  dcr c!
bb49 bb49 d c246bb
bb49 bb49 u 03 01
bb49 bb49 s  jnz make0
bb4c bb4c d 210d00
bb4c bb4c u 03 01
bb4c bb4c s 	lxi h,ubytes!
bb4f bb4f d 19
bb4f bb4f u 01 01
bb4f bb4f s  dad d ;HL = .fcb(ubytes)
bb50 bb50 d 77
bb50 bb50 u 01 01
bb50 bb50 s 	mov m,a ;fcb(ubytes) = 0
bb51 bb51 d cd8cb7
bb51 bb51 u 03 01
bb51 bb51 s 	call setcdr ;may have extended the directory
bb54 bb54 s 	;now copy entry to the directory
bb54 bb54 d cdfdb9
bb54 bb54 u 03 01
bb54 bb54 s 	call copy$fcb
bb57 bb57 s 	;and set the file write flag to "1"
bb57 bb57 d c378b7
bb57 bb57 u 03 01
bb57 bb57 s 	jmp setfwf
bb5a bb5a s 	;ret
bb5a bb5a s ;
bb5a bb5a s open$reel:
bb5a bb5a s 	;close the current extent, and open the next one
bb5a bb5a s 	;if possible.  RMF is true if in read mode
bb5a bb5a d af
bb5a bb5a u 01 01
bb5a bb5a s 		xra a!
bb5b bb5b d 32d2bf
bb5b bb5b u 03 01
bb5b bb5b s  sta fcb$copied ;set true if actually copied
bb5e bb5e d cda2ba
bb5e bb5e u 03 01
bb5e bb5e s 		call close ;close current extent
bb61 bb61 s 		;lret remains at enddir if we cannot open the next ext
bb61 bb61 d cdf5b7
bb61 bb61 u 03 01
bb61 bb61 s 		call end$of$dir!
bb64 bb64 d c8
bb64 bb64 u 01 01
bb64 bb64 s  rz ;return if end
bb65 bb65 s 	;increment extent number
bb65 bb65 d 2a43b5
bb65 bb65 u 03 01
bb65 bb65 s 	lhld info!
bb68 bb68 d 010c00
bb68 bb68 u 03 01
bb68 bb68 s  lxi b,extnum!
bb6b bb6b d 09
bb6b bb6b u 01 01
bb6b bb6b s  dad b ;HL=.fcb(extnum)
bb6c bb6c d 7e
bb6c bb6c u 01 01
bb6c bb6c s 	mov a,m!
bb6d bb6d d 3c
bb6d bb6d u 01 01
bb6d bb6d s  inr a!
bb6e bb6e d e61f
bb6e bb6e u 02 01
bb6e bb6e s  ani maxext!
bb70 bb70 d 77
bb70 bb70 u 01 01
bb70 bb70 s  mov m,a ;fcb(extnum)=++1
bb71 bb71 d ca83bb
bb71 bb71 u 03 01
bb71 bb71 s 	jz open$mod ;move to next module if zero
bb74 bb74 s 	;may be in the same extent group
bb74 bb74 d 47
bb74 bb74 u 01 01
bb74 bb74 s 	mov b,a!
bb75 bb75 d 3ac5bf
bb75 bb75 u 03 01
bb75 bb75 s  lda extmsk!
bb78 bb78 d a0
bb78 bb78 u 01 01
bb78 bb78 s  ana b
bb79 bb79 s 	;if result is zero, then not in the same group
bb79 bb79 d 21d2bf
bb79 bb79 u 03 01
bb79 bb79 s 	lxi h,fcb$copied ;true if the fcb was copied to directory
bb7c bb7c d a6
bb7c bb7c u 01 01
bb7c bb7c s 	ana m ;produces a 00 in accumulator if not written
bb7d bb7d d ca8ebb
bb7d bb7d u 03 01
bb7d bb7d s 	jz open$reel0 ;go to next physical extent
bb80 bb80 s 	;result is non zero, so we must be in same logical ext
bb80 bb80 d c3acbb
bb80 bb80 u 03 01
bb80 bb80 s 	jmp open$reel1 ;to copy fcb information
bb83 bb83 s 	open$mod:
bb83 bb83 s 		;extent number overflow, go to next module
bb83 bb83 d 010200
bb83 bb83 u 03 01
bb83 bb83 s 		lxi b,(modnum-extnum)!
bb86 bb86 d 09
bb86 bb86 u 01 01
bb86 bb86 s  dad b ;HL=.fcb(modnum)
bb87 bb87 d 34
bb87 bb87 u 01 01
bb87 bb87 s 		inr m ;fcb(modnum)=++1
bb88 bb88 s 		;module number incremented, check for overflow
bb88 bb88 d 7e
bb88 bb88 u 01 01
bb88 bb88 s 		mov a,m!
bb89 bb89 d e60f
bb89 bb89 u 02 01
bb89 bb89 s  ani maxmod ;mask high order bits
bb8b bb8b d cab6bb
bb8b bb8b u 03 01
bb8b bb8b s 		jz open$r$err ;cannot overflow to zero
bb8e bb8e s 		;otherwise, ok to continue with new module
bb8e bb8e s 	open$reel0:
bb8e bb8e d 0e0f
bb8e bb8e u 02 01
bb8e bb8e s 		mvi c,namlen!
bb90 bb90 d cd18b9
bb90 bb90 u 03 01
bb90 bb90 s  call search ;next extent found?
bb93 bb93 d cdf5b7
bb93 bb93 u 03 01
bb93 bb93 s 		call end$of$dir!
bb96 bb96 d c2acbb
bb96 bb96 u 03 01
bb96 bb96 s  jnz open$reel1
bb99 bb99 s 			;end of file encountered
bb99 bb99 d 3ad3bf
bb99 bb99 u 03 01
bb99 bb99 s 			lda rmf!
bb9c bb9c d 3c
bb9c bb9c u 01 01
bb9c bb9c s  inr a ;0ffh becomes 00 if read
bb9d bb9d d cab6bb
bb9d bb9d u 03 01
bb9d bb9d s 			jz open$r$err ;sets lret = 1
bba0 bba0 s 			;try to extend the current file
bba0 bba0 d cd24bb
bba0 bba0 u 03 01
bba0 bba0 s 			call make
bba3 bba3 s 			;cannot be end of directory
bba3 bba3 d cdf5b7
bba3 bba3 u 03 01
bba3 bba3 s 			call end$of$dir
bba6 bba6 d cab6bb
bba6 bba6 u 03 01
bba6 bba6 s 			jz open$r$err ;with lret = 1
bba9 bba9 d c3afbb
bba9 bba9 u 03 01
bba9 bba9 s 			jmp open$reel2
bbac bbac s 		open$reel1:
bbac bbac s 			;not end of file, open
bbac bbac d cd5aba
bbac bbac u 03 01
bbac bbac s 			call open$copy
bbaf bbaf s 		open$reel2:
bbaf bbaf d cdbbb6
bbaf bbaf u 03 01
bbaf bbaf s 			call getfcb ;set parameters
bbb2 bbb2 d af
bbb2 bbb2 u 01 01
bbb2 bbb2 s 			xra a!
bbb3 bbb3 d c301b5
bbb3 bbb3 u 03 01
bbb3 bbb3 s  jmp sta$ret ;lret = 0	;
bbb6 bbb6 s ;			ret ;with lret = 0
bbb6 bbb6 s 	open$r$err:
bbb6 bbb6 s 		;cannot move to next extent of this file
bbb6 bbb6 d cd05b5
bbb6 bbb6 u 03 01
bbb6 bbb6 s 		call setlret1 ;lret = 1
bbb9 bbb9 d c378b7
bbb9 bbb9 u 03 01
bbb9 bbb9 s 		jmp setfwf ;ensure that it will not be closed
bbbc bbbc s 		;ret
bbbc bbbc s ;
bbbc bbbc s seqdiskread:
bbbc bbbc s 	;sequential disk read operation
bbbc bbbc d 3e01
bbbc bbbc u 02 01
bbbc bbbc s 	mvi a,1!
bbbe bbbe d 32d5bf
bbbe bbbe u 03 01
bbbe bbbe s  sta seqio
bbc1 bbc1 s 	;drop through to diskread
bbc1 bbc1 s ;
bbc1 bbc1 s diskread:	;(may enter from seqdiskread)
bbc1 bbc1 d 3eff
bbc1 bbc1 u 02 01
bbc1 bbc1 s 	mvi a,true!
bbc3 bbc3 d 32d3bf
bbc3 bbc3 u 03 01
bbc3 bbc3 s  sta rmf ;read mode flag = true (open$reel)
bbc6 bbc6 s 	;read the next record from the current fcb
bbc6 bbc6 d cdbbb6
bbc6 bbc6 u 03 01
bbc6 bbc6 s 	call getfcb ;sets parameters for the read
bbc9 bbc9 d 3ae3bf
bbc9 bbc9 u 03 01
bbc9 bbc9 s 	lda vrecord!
bbcc bbcc d 21e1bf
bbcc bbcc u 03 01
bbcc bbcc s  lxi h,rcount!
bbcf bbcf d be
bbcf bbcf u 01 01
bbcf bbcf s  cmp m ;vrecord-rcount
bbd0 bbd0 s 	;skip if rcount > vrecord
bbd0 bbd0 d dae6bb
bbd0 bbd0 u 03 01
bbd0 bbd0 s 	jc recordok
bbd3 bbd3 s 		;not enough records in the extent
bbd3 bbd3 s 		;record count must be 128 to continue
bbd3 bbd3 d fe80
bbd3 bbd3 u 02 01
bbd3 bbd3 s 		cpi 128 ;vrecord = 128?
bbd5 bbd5 d c2fbbb
bbd5 bbd5 u 03 01
bbd5 bbd5 s 		jnz diskeof ;skip if vrecord<>128
bbd8 bbd8 d cd5abb
bbd8 bbd8 u 03 01
bbd8 bbd8 s 		call open$reel ;go to next extent if so
bbdb bbdb d af
bbdb bbdb u 01 01
bbdb bbdb s 		xra a!
bbdc bbdc d 32e3bf
bbdc bbdc u 03 01
bbdc bbdc s  sta vrecord ;vrecord=00
bbdf bbdf s 		;now check for open ok
bbdf bbdf d 3a45b5
bbdf bbdf u 03 01
bbdf bbdf s 		lda lret!
bbe2 bbe2 d b7
bbe2 bbe2 u 01 01
bbe2 bbe2 s  ora a!
bbe3 bbe3 d c2fbbb
bbe3 bbe3 u 03 01
bbe3 bbe3 s  jnz diskeof ;stop at eof
bbe6 bbe6 s 	recordok:
bbe6 bbe6 s 		;arrive with fcb addressing a record to read
bbe6 bbe6 d cd77b6
bbe6 bbe6 u 03 01
bbe6 bbe6 s 		call index
bbe9 bbe9 s 		;error 2 if reading unwritten data
bbe9 bbe9 s 		;(returns 1 to be compatible with 1.4)
bbe9 bbe9 d cd84b6
bbe9 bbe9 u 03 01
bbe9 bbe9 s 		call allocated ;arecord=0000?
bbec bbec d cafbbb
bbec bbec u 03 01
bbec bbec s 		jz diskeof
bbef bbef s 		;record has been allocated, read it
bbef bbef d cd8ab6
bbef bbef u 03 01
bbef bbef s 		call atran ;arecord now a disk address
bbf2 bbf2 d cdd1b5
bbf2 bbf2 u 03 01
bbf2 bbf2 s 		call seek ;to proper track,sector
bbf5 bbf5 d cdb2b5
bbf5 bbf5 u 03 01
bbf5 bbf5 s 		call rdbuff ;to dma address
bbf8 bbf8 d c3d2b6
bbf8 bbf8 u 03 01
bbf8 bbf8 s 		jmp setfcb ;replace parameter	
bbfb bbfb s ;		ret					;
bbfb bbfb s 	diskeof:
bbfb bbfb d c305b5
bbfb bbfb u 03 01
bbfb bbfb s 		jmp setlret1 ;lret = 1
bbfe bbfe s 		;ret
bbfe bbfe s ;
bbfe bbfe s seqdiskwrite:
bbfe bbfe s 	;sequential disk write
bbfe bbfe d 3e01
bbfe bbfe u 02 01
bbfe bbfe s 	mvi a,1!
bc00 bc00 d 32d5bf
bc00 bc00 u 03 01
bc00 bc00 s  sta seqio
bc03 bc03 s 	;drop through to diskwrite
bc03 bc03 s ;
bc03 bc03 s diskwrite:	;(may enter here from seqdiskwrite above)
bc03 bc03 d 3e00
bc03 bc03 u 02 01
bc03 bc03 s 	mvi a,false!
bc05 bc05 d 32d3bf
bc05 bc05 u 03 01
bc05 bc05 s  sta rmf ;read mode flag
