b9be b9be s get$block:
b9be b9be s 	;given allocation vector position BC, find the zero bit
b9be b9be s 	;closest to this position by searching left and right.
b9be b9be s 	;if found, set the bit to one and return the bit position
b9be b9be s 	;in hl.  if not found (i.e., we pass 0 on the left, or
b9be b9be s 	;maxall on the right), return 0000 in hl
b9be b9be d 50
b9be b9be u 01 01
b9be b9be s 	mov d,b!
b9bf b9bf d 59
b9bf b9bf u 01 01
b9bf b9bf s  mov e,c ;copy of starting position to de
b9c0 b9c0 s 	lefttst:
b9c0 b9c0 d 79
b9c0 b9c0 u 01 01
b9c0 b9c0 s 		mov a,c!
b9c1 b9c1 d b0
b9c1 b9c1 u 01 01
b9c1 b9c1 s  ora b!
b9c2 b9c2 d cad1b9
b9c2 b9c2 u 03 01
b9c2 b9c2 s  jz righttst ;skip if left=0000
b9c5 b9c5 s 		;left not at position zero, bit zero?
b9c5 b9c5 d 0b
b9c5 b9c5 u 01 01
b9c5 b9c5 s 		dcx b!
b9c6 b9c6 d d5
b9c6 b9c6 u 01 01
b9c6 b9c6 s  push d!
b9c7 b9c7 d c5
b9c7 b9c7 u 01 01
b9c7 b9c7 s  push b ;left,right pushed
b9c8 b9c8 d cd35b8
b9c8 b9c8 u 03 01
b9c8 b9c8 s 		call getallocbit
b9cb b9cb d 1f
b9cb b9cb u 01 01
b9cb b9cb s 		rar!
b9cc b9cc d d2ecb9
b9cc b9cc u 03 01
b9cc b9cc s  jnc retblock ;return block number if zero
b9cf b9cf s 		;bit is one, so try the right
b9cf b9cf d c1
b9cf b9cf u 01 01
b9cf b9cf s 		pop b!
b9d0 b9d0 d d1
b9d0 b9d0 u 01 01
b9d0 b9d0 s  pop d ;left, right restored
b9d1 b9d1 s 	righttst:
b9d1 b9d1 d 2ac6bf
b9d1 b9d1 u 03 01
b9d1 b9d1 s 		lhld maxall ;value of maximum allocation#
b9d4 b9d4 d 7b
b9d4 b9d4 u 01 01
