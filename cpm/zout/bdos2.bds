b845 b845 u 01 01
b845 b845 s  add a!
b846 b846 d 87
b846 b846 u 01 01
b846 b846 s  add a!
b847 b847 d 87
b847 b847 u 01 01
b847 b847 s  add a ;B shl 5
b848 b848 d b1
b848 b848 u 01 01
b848 b848 s 	ora c!
b849 b849 d 4f
b849 b849 u 01 01
b849 b849 s  mov c,a ;bbbccccc to C
b84a b84a d 78
b84a b84a u 01 01
