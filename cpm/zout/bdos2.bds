b9f1 b9f1 d e1
b9f1 b9f1 u 01 01
b9f1 b9f1 s 		pop h!
b9f2 b9f2 d d1
b9f2 b9f2 u 01 01
b9f2 b9f2 s  pop d ;HL returned value, DE discarded
b9f3 b9f3 d c9
b9f3 b9f3 u 01 01
b9f3 b9f3 s 		ret
b9f4 b9f4 s 	retblock0:
