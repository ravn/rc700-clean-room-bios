b547 b547 s ;
b547 b547 s dvers	equ	22h	;version 2.2
b547 b547 s ;	module addresses
b547 b547 s ;
b547 b547 s ;	literal constants
b547 b547 s true	equ	0ffh	;constant true
b547 b547 s false	equ	000h	;constant false
b547 b547 s enddir	equ	0ffffh	;end of directory
b547 b547 s byte	equ	1	;number of bytes for "byte" type
b547 b547 s word	equ	2	;number of bytes for "word" type
b547 b547 s ;
b547 b547 s ;	fixed addresses in low memory
b547 b547 s tfcb	equ	005ch	;default fcb location
b547 b547 s tbuff	equ	0080h	;default buffer location
b547 b547 s ;
