b8cf b8cf s 	;cdrmax = 0000
b8cf b8cf d cdfeb7
b8cf b8cf u 03 01
b8cf b8cf s 	call set$end$dir ;dcnt = enddir
b8d2 b8d2 s 	;read directory entries and check for allocated storage
b8d2 b8d2 s 	initial2:
b8d2 b8d2 d 0eff
