b744 b744 s 	call getdptra ;address of element
b747 b747 s ;						
b747 b747 s check$rofile:
b747 b747 s 	;check current buff(dptr) or fcb(0) for r/o status
b747 b747 d 110900
b747 b747 u 03 01
b747 b747 s 	lxi d,rofile!
b74a b74a d 19
b74a b74a u 01 01
b74a b74a s  dad d ;offset to ro bit
b74b b74b d 7e
b74b b74b u 01 01
b74b b74b s 	mov a,m!
b74c b74c d 17
b74c b74c u 01 01
b74c b74c s  ral!
b74d b74d d d0
b74d b74d u 01 01
b74d b74d s  rnc ;return if not set
b74e b74e d 210fb2
b74e b74e u 03 01
b74e b74e s 	lxi h,roferr!
b751 b751 d c34ab5
b751 b751 u 03 01
b751 b751 s  jmp goerr			;
b754 b754 s ;	jmp rof$error ;exit to read only disk message
b754 b754 s ;
b754 b754 s ;
b754 b754 s check$write:
b754 b754 s 	;check for write protected disk
b754 b754 d cd1eb7
b754 b754 u 03 01
b754 b754 s 	call nowrite!
b757 b757 d c8
b757 b757 u 01 01
b757 b757 s  rz ;ok to write if not rodsk
b758 b758 d 210db2
