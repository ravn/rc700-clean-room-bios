bab0 bab0 s 	;check file write flag - 0 indicates written
bab0 bab0 d cd69b7
bab0 bab0 u 03 01
bab0 bab0 s 	call getmodnum ;fcb(modnum) in A
bab3 bab3 d e680
bab3 bab3 u 02 01
bab3 bab3 s 	ani fwfmsk!
bab5 bab5 d c0
bab5 bab5 u 01 01
bab5 bab5 s  rnz ;return if bit remains set
bab6 bab6 d 0e0f
bab6 bab6 u 02 01
bab6 bab6 s 	mvi c,namlen!
bab8 bab8 d cd18b9
bab8 bab8 u 03 01
bab8 bab8 s  call search ;locate file
babb babb d cdf5b7
babb babb u 03 01
babb babb s 	call end$of$dir!
babe babe d c8
babe babe u 01 01
babe babe s  rz ;return if not found
babf babf s 	;merge the disk map at info with that at buff(dptr)
babf babf d 011000
babf babf u 03 01
babf babf s 	lxi b,dskmap!
bac2 bac2 d cd5eb7
bac2 bac2 u 03 01
bac2 bac2 s  call getdptra
bac5 bac5 d 09
bac5 bac5 u 01 01
bac5 bac5 s 	dad b!
bac6 bac6 d eb
bac6 bac6 u 01 01
bac6 bac6 s  xchg ;DE is .buff(dptr+16)
bac7 bac7 d 2a43b5
bac7 bac7 u 03 01
