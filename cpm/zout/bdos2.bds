bfc1 bfc1 s ;	(data must be adjacent, do not insert variables)
bfc1 bfc1 s sectpt:	ds	word	;sectors per track
bfc3 bfc3 s blkshf:	ds	byte	;block shift factor
bfc4 bfc4 s blkmsk:	ds	byte	;block mask
bfc5 bfc5 s extmsk:	ds	byte	;extent mask
bfc6 bfc6 s maxall:	ds	word	;maximum allocation number
bfc8 bfc8 s dirmax:	ds	word	;largest directory number
bfca bfca s dirblk:	ds	word	;reserved allocation bits for directory
bfcc bfcc s chksiz:	ds	word	;size of checksum vector
bfce bfce s offset:	ds	word	;offset tracks at beginning
bfd0 bfd0 s dpblist	equ	$-sectpt	;size of area
