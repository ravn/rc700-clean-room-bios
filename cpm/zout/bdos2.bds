b8bd b8bd d eb
b8bd b8bd u 01 01
b8bd b8bd s  xchg
b8be b8be d 2abfbf
b8be b8be u 03 01
b8be b8be s 	lhld alloca ;HL=.alloc()
b8c1 b8c1 d 73
b8c1 b8c1 u 01 01
