b835 b835 s ;
b835 b835 s getallocbit:
b835 b835 s 	;given allocation vector position BC, return with byte
b835 b835 s 	;containing BC shifted so that the least significant
b835 b835 s 	;bit is in the low order accumulator position.  HL is
b835 b835 s 	;the address of the byte for possible replacement in
b835 b835 s 	;memory upon return, and D contains the number of shifts
b835 b835 s 	;required to place the returned value back into position
b835 b835 d 79
b835 b835 u 01 01
b835 b835 s 	mov a,c!
b836 b836 d e607
b836 b836 u 02 01
b836 b836 s  ani 111b!
b838 b838 d 3c
b838 b838 u 01 01
b838 b838 s  inr a!
b839 b839 d 5f
b839 b839 u 01 01
b839 b839 s  mov e,a!
b83a b83a d 57
b83a b83a u 01 01
b83a b83a s  mov d,a
