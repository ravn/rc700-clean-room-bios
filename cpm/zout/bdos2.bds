b5f4 b5f4 s  mov crech,a
b5f5 b5f5 d e1
b5f5 b5f5 u 01 01
b5f5 b5f5 s 			pop ctrkh
b5f6 b5f6 s 			;curtrk = curtrk - 1
b5f6 b5f6 d 2b
b5f6 b5f6 u 01 01
b5f6 b5f6 s 			dcx ctrkh
b5f7 b5f7 d c3e4b5
b5f7 b5f7 u 03 01
b5f7 b5f7 s 		jmp seek0 ;for another try
b5fa b5fa s 	seek1:
b5fa b5fa s 	;look while arecord >= (t:=currec + sectpt)
b5fa b5fa d e5
b5fa b5fa u 01 01
b5fa b5fa s 		push ctrkh
b5fb b5fb d 2ac1bf
b5fb b5fb u 03 01
b5fb b5fb s 		lhld sectpt!
b5fe b5fe d 19
b5fe b5fe u 01 01
b5fe b5fe s  dad crech ;HL = currec+sectpt
b5ff b5ff d da0fb6
b5ff b5ff u 03 01
b5ff b5ff s 		  jc seek2		;can be > FFFFH	
b602 b602 d 79
b602 b602 u 01 01
b602 b602 s 		mov a,arecl!
b603 b603 d 95
b603 b603 u 01 01
b603 b603 s  sub tcrecl!
b604 b604 d 78
b604 b604 u 01 01
b604 b604 s  mov a,arech!
b605 b605 d 9c
b605 b605 u 01 01
b605 b605 s  sbb tcrech
b606 b606 d da0fb6
b606 b606 u 03 01
b606 b606 s 		jc seek2 ;skip if t > arecord
b609 b609 s 			;currec = t
b609 b609 d eb
b609 b609 u 01 01
b609 b609 s 			xchg
b60a b60a s 			;curtrk = curtrk + 1
b60a b60a d e1
b60a b60a u 01 01
b60a b60a s 			pop ctrkh!
b60b b60b d 23
b60b b60b u 01 01
b60b b60b s  inx ctrkh
b60c b60c d c3fab5
b60c b60c u 03 01
b60c b60c s 		jmp seek1 ;for another try
b60f b60f d e1
b60f b60f u 01 01
b60f b60f s 	seek2:	pop ctrkh
b610 b610 s 	;arrive here with updated values in each register
b610 b610 d c5
b610 b610 u 01 01
b610 b610 s 	push arech!
b611 b611 d d5
b611 b611 u 01 01
b611 b611 s  push crech!
b612 b612 d e5
b612 b612 u 01 01
b612 b612 s  push ctrkh ;to stack for later
b613 b613 s 	;stack contains (lowest) BC=arecord, DE=currec, HL=curtrk
b613 b613 d eb
b613 b613 u 01 01
b613 b613 s 	xchg!
b614 b614 d 2acebf
b614 b614 u 03 01
b614 b614 s  lhld offset!
b617 b617 d 19
b617 b617 u 01 01
b617 b617 s  dad d ;HL = curtrk+offset
b618 b618 d 44
b618 b618 u 01 01
b618 b618 s 	mov b,h!
b619 b619 d 4d
b619 b619 u 01 01
b619 b619 s  mov c,l!
b61a b61a d cd1ec0
b61a b61a u 03 01
b61a b61a s  call settrkf ;track set up
b61d b61d s 	;note that BC - curtrk is difference to move in bios
b61d b61d d d1
b61d b61d u 01 01
b61d b61d s 	pop d ;recall curtrk
b61e b61e d 2ab5bf
b61e b61e u 03 01
b61e b61e s 	lhld curtrka!
b621 b621 d 73
b621 b621 u 01 01
b621 b621 s  mov m,e!
b622 b622 d 23
b622 b622 u 01 01
b622 b622 s  inx h!
b623 b623 d 72
b623 b623 u 01 01
b623 b623 s  mov m,d ;curtrk updated
b624 b624 s 	;now compute sector as arecord-currec
b624 b624 d d1
b624 b624 u 01 01
b624 b624 s 	pop crech ;recall currec
b625 b625 d 2ab7bf
b625 b625 u 03 01
b625 b625 s 	lhld curreca!
b628 b628 d 73
b628 b628 u 01 01
b628 b628 s  mov m,crecl!
b629 b629 d 23
b629 b629 u 01 01
b629 b629 s  inx h!
b62a b62a d 72
b62a b62a u 01 01
b62a b62a s  mov m,crech
b62b b62b d c1
b62b b62b u 01 01
b62b b62b s 	pop arech ;BC=arecord, DE=currec
b62c b62c d 79
b62c b62c u 01 01
b62c b62c s 	mov a,arecl!
b62d b62d d 93
b62d b62d u 01 01
b62d b62d s  sub crecl!
b62e b62e d 4f
b62e b62e u 01 01
b62e b62e s  mov arecl,a
b62f b62f d 78
b62f b62f u 01 01
b62f b62f s 	mov a,arech!
b630 b630 d 9a
b630 b630 u 01 01
b630 b630 s  sbb crech!
b631 b631 d 47
b631 b631 u 01 01
b631 b631 s  mov arech,a
b632 b632 d 2ad0bf
b632 b632 u 03 01
b632 b632 s 	lhld tranv!
b635 b635 d eb
b635 b635 u 01 01
b635 b635 s  xchg ;BC=sector#, DE=.tran
b636 b636 d cd30c0
b636 b636 u 03 01
b636 b636 s 	call sectran ;HL = tran(sector)
b639 b639 d 4d
b639 b639 u 01 01
b639 b639 s 	mov c,l!
b63a b63a d 44
b63a b63a u 01 01
b63a b63a s  mov b,h ;BC = tran(sector)
b63b b63b d c321c0
b63b b63b u 03 01
b63b b63b s 	jmp setsecf ;sector selected
b63e b63e s 	;ret
b63e b63e s ;
b63e b63e s ;	file control block (fcb) constants
b63e b63e s empty	equ	0e5h	;empty directory entry
b63e b63e s lstrec	equ	127	;last record# in extent
b63e b63e s recsiz	equ	128	;record size
b63e b63e s fcblen	equ	32	;file control block size
b63e b63e s dirrec	equ	recsiz/fcblen	;directory elts / record
b63e b63e s dskshf	equ	2	;log2(dirrec)
b63e b63e s dskmsk	equ	dirrec-1
b63e b63e s fcbshf	equ	5	;log2(fcblen)
b63e b63e s ;
b63e b63e s extnum	equ	12	;extent number field
b63e b63e s maxext	equ	31	;largest extent number
b63e b63e s ubytes	equ	13	;unfilled bytes field
b63e b63e s modnum	equ	14	;data module number
b63e b63e s maxmod	equ	15	;largest module number
b63e b63e s fwfmsk	equ	80h	;file write flag is high order modnum
b63e b63e s namlen	equ	15	;name length
b63e b63e s reccnt	equ	15	;record count field
b63e b63e s dskmap	equ	16	;disk map field
b63e b63e s lstfcb	equ	fcblen-1
b63e b63e s nxtrec	equ	fcblen
b63e b63e s ranrec	equ	nxtrec+1;random record field (2 bytes)
b63e b63e s ;
b63e b63e s ;	reserved file indicators
b63e b63e s rofile	equ	9	;high order of first type char
b63e b63e s invis	equ	10	;invisible file in dir command
b63e b63e s ;	equ	11	;reserved
b63e b63e s ;
b63e b63e s ;	utility functions for file access
b63e b63e s ;
b63e b63e s dm$position:
b63e b63e s 	;compute disk map position for vrecord to HL
b63e b63e d 21c3bf
b63e b63e u 03 01
b63e b63e s 	lxi h,blkshf!
b641 b641 d 4e
b641 b641 u 01 01
b641 b641 s  mov c,m ;shift count to C
b642 b642 d 3ae3bf
b642 b642 u 03 01
b642 b642 s 	lda vrecord ;current virtual record to A
b645 b645 s 	dmpos0:
b645 b645 d b7
b645 b645 u 01 01
b645 b645 s 		ora a!
b646 b646 d 1f
b646 b646 u 01 01
b646 b646 s  rar!
b647 b647 d 0d
b647 b647 u 01 01
b647 b647 s  dcr c!
b648 b648 d c245b6
b648 b648 u 03 01
b648 b648 s  jnz dmpos0
b64b b64b s 	;A = shr(vrecord,blkshf) = vrecord/2**(sect/block)
b64b b64b d 47
b64b b64b u 01 01
b64b b64b s 	mov b,a ;save it for later addition
b64c b64c d 3e08
b64c b64c u 02 01
b64c b64c s 	mvi a,8!
b64e b64e d 96
b64e b64e u 01 01
b64e b64e s  sub m ;8-blkshf to accumulator
b64f b64f d 4f
b64f b64f u 01 01
b64f b64f s 	mov c,a ;extent shift count in register c
b650 b650 d 3ae2bf
b650 b650 u 03 01
b650 b650 s 	lda extval ;extent value ani extmsk
b653 b653 s 	dmpos1:
b653 b653 s 		;blkshf = 3,4,5,6,7, C=5,4,3,2,1
b653 b653 s 		;shift is 4,3,2,1,0
b653 b653 d 0d
b653 b653 u 01 01
b653 b653 s 		dcr c!
b654 b654 d ca5cb6
b654 b654 u 03 01
b654 b654 s  jz dmpos2
b657 b657 d b7
b657 b657 u 01 01
b657 b657 s 		ora a!
b658 b658 d 17
b658 b658 u 01 01
b658 b658 s  ral!
b659 b659 d c353b6
b659 b659 u 03 01
b659 b659 s  jmp dmpos1
b65c b65c s 	dmpos2:
b65c b65c s 	;arrive here with A = shl(ext and extmsk,7-blkshf)
b65c b65c d 80
b65c b65c u 01 01
b65c b65c s 	add b ;add the previous shr(vrecord,blkshf) value
b65d b65d s 	;A is one of the following values, depending upon alloc
b65d b65d s 	;bks blkshf
b65d b65d s 	;1k   3     v/8 + extval * 16
b65d b65d s 	;2k   4     v/16+ extval * 8
b65d b65d s 	;4k   5     v/32+ extval * 4
b65d b65d s 	;8k   6     v/64+ extval * 2
b65d b65d s 	;16k  7     v/128+extval * 1
b65d b65d d c9
b65d b65d u 01 01
b65d b65d s 	ret ;with dm$position in A
b65e b65e s ;
b65e b65e s getdm:
b65e b65e s 	;return disk map value from position given by BC
b65e b65e d 2a43b5
b65e b65e u 03 01
b65e b65e s 	lhld info ;base address of file control block
b661 b661 d 111000
b661 b661 u 03 01
b661 b661 s 	lxi d,dskmap!
b664 b664 d 19
b664 b664 u 01 01
b664 b664 s  dad d ;HL =.diskmap
b665 b665 d 09
b665 b665 u 01 01
b665 b665 s 	dad b ;index by a single byte value
b666 b666 d 3addbf
b666 b666 u 03 01
b666 b666 s 	lda single ;single byte/map entry?
b669 b669 d b7
b669 b669 u 01 01
b669 b669 s 	ora a!
b66a b66a d ca71b6
b66a b66a u 03 01
b66a b66a s  jz getdmd ;get disk map single byte
b66d b66d d 6e
b66d b66d u 01 01
b66d b66d s 		mov l,m!
b66e b66e d 2600
b66e b66e u 02 01
b66e b66e s  mvi h,0!
b670 b670 d c9
b670 b670 u 01 01
b670 b670 s  ret ;with HL=00bb
b671 b671 s 	getdmd:
b671 b671 d 09
b671 b671 u 01 01
b671 b671 s 		dad b ;HL=.fcb(dm+i*2)
b672 b672 s 		;double precision value returned
b672 b672 d 5e
b672 b672 u 01 01
b672 b672 s 		mov e,m!
b673 b673 d 23
b673 b673 u 01 01
b673 b673 s  inx h!
b674 b674 d 56
b674 b674 u 01 01
b674 b674 s  mov d,m!
b675 b675 d eb
b675 b675 u 01 01
b675 b675 s  xchg!
b676 b676 d c9
b676 b676 u 01 01
b676 b676 s  ret
b677 b677 s ;
b677 b677 s index:
b677 b677 s 	;compute disk block number from current fcb
b677 b677 d cd3eb6
b677 b677 u 03 01
b677 b677 s 	call dm$position ;0...15 in register A
b67a b67a d 4f
b67a b67a u 01 01
b67a b67a s 	mov c,a!
b67b b67b d 0600
b67b b67b u 02 01
b67b b67b s  mvi b,0!
b67d b67d d cd5eb6
b67d b67d u 03 01
b67d b67d s  call getdm ;value to HL
b680 b680 d 22e5bf
b680 b680 u 03 01
b680 b680 s 	shld arecord!
b683 b683 d c9
b683 b683 u 01 01
b683 b683 s  ret
b684 b684 s ;
b684 b684 s allocated:
b684 b684 s 	;called following index to see if block allocated
b684 b684 d 2ae5bf
b684 b684 u 03 01
b684 b684 s 	lhld arecord!
b687 b687 d 7d
b687 b687 u 01 01
b687 b687 s  mov a,l!
b688 b688 d b4
b688 b688 u 01 01
b688 b688 s  ora h!
b689 b689 d c9
b689 b689 u 01 01
b689 b689 s  ret
b68a b68a s ;
b68a b68a s atran:
b68a b68a s 	;compute actual record address, assuming index called
b68a b68a d 3ac3bf
b68a b68a u 03 01
b68a b68a s 	lda blkshf ;shift count to reg A
b68d b68d d 2ae5bf
b68d b68d u 03 01
b68d b68d s 	lhld arecord
b690 b690 s 	atran0:
b690 b690 d 29
b690 b690 u 01 01
b690 b690 s 		dad h!
b691 b691 d 3d
b691 b691 u 01 01
b691 b691 s  dcr a!
b692 b692 d c290b6
b692 b692 u 03 01
b692 b692 s  jnz atran0 ;shl(arecord,blkshf)
b695 b695 d 22e7bf
b695 b695 u 03 01
b695 b695 s 		shld arecord1		;save shifted block #  
b698 b698 d 3ac4bf
b698 b698 u 03 01
b698 b698 s 	lda blkmsk!
b69b b69b d 4f
b69b b69b u 01 01
b69b b69b s  mov c,a ;mask value to C
b69c b69c d 3ae3bf
b69c b69c u 03 01
b69c b69c s 	lda vrecord!
b69f b69f d a1
b69f b69f u 01 01
b69f b69f s  ana c ;masked value in A
b6a0 b6a0 d b5
b6a0 b6a0 u 01 01
b6a0 b6a0 s 	ora l!
b6a1 b6a1 d 6f
b6a1 b6a1 u 01 01
b6a1 b6a1 s  mov l,a ;to HL
b6a2 b6a2 d 22e5bf
b6a2 b6a2 u 03 01
b6a2 b6a2 s 	shld arecord ;arecord=HL or (vrecord and blkmsk)
b6a5 b6a5 d c9
b6a5 b6a5 u 01 01
b6a5 b6a5 s 	ret
b6a6 b6a6 s ;
b6a6 b6a6 s getexta:
b6a6 b6a6 s 	;get current extent field address to A
b6a6 b6a6 d 2a43b5
b6a6 b6a6 u 03 01
b6a6 b6a6 s 	lhld info!
b6a9 b6a9 d 110c00
b6a9 b6a9 u 03 01
b6a9 b6a9 s  lxi d,extnum!
b6ac b6ac d 19
b6ac b6ac u 01 01
b6ac b6ac s  dad d ;HL=.fcb(extnum)
b6ad b6ad d c9
b6ad b6ad u 01 01
b6ad b6ad s 	ret
b6ae b6ae s ;
b6ae b6ae s getfcba:
b6ae b6ae s 	;compute reccnt and nxtrec addresses for get/setfcb
b6ae b6ae d 2a43b5
b6ae b6ae u 03 01
b6ae b6ae s 	lhld info!
b6b1 b6b1 d 110f00
b6b1 b6b1 u 03 01
b6b1 b6b1 s  lxi d,reccnt!
b6b4 b6b4 d 19
b6b4 b6b4 u 01 01
b6b4 b6b4 s  dad d!
b6b5 b6b5 d eb
b6b5 b6b5 u 01 01
b6b5 b6b5 s  xchg ;DE=.fcb(reccnt)
b6b6 b6b6 d 211100
b6b6 b6b6 u 03 01
b6b6 b6b6 s 	lxi h,(nxtrec-reccnt)!
b6b9 b6b9 d 19
b6b9 b6b9 u 01 01
b6b9 b6b9 s  dad d ;HL=.fcb(nxtrec)
b6ba b6ba d c9
b6ba b6ba u 01 01
b6ba b6ba s 	ret
b6bb b6bb s ;
b6bb b6bb s getfcb:
b6bb b6bb s 	;set variables from currently addressed fcb
b6bb b6bb d cdaeb6
b6bb b6bb u 03 01
b6bb b6bb s 	call getfcba ;addresses in DE, HL
b6be b6be d 7e
b6be b6be u 01 01
b6be b6be s 	mov a,m!
b6bf b6bf d 32e3bf
b6bf b6bf u 03 01
b6bf b6bf s  sta vrecord ;vrecord=fcb(nxtrec)
b6c2 b6c2 d eb
b6c2 b6c2 u 01 01
b6c2 b6c2 s 	xchg!
b6c3 b6c3 d 7e
b6c3 b6c3 u 01 01
b6c3 b6c3 s  mov a,m!
b6c4 b6c4 d 32e1bf
b6c4 b6c4 u 03 01
b6c4 b6c4 s  sta rcount ;rcount=fcb(reccnt)
b6c7 b6c7 d cda6b6
b6c7 b6c7 u 03 01
b6c7 b6c7 s 	call getexta ;HL=.fcb(extnum)
b6ca b6ca d 3ac5bf
b6ca b6ca u 03 01
b6ca b6ca s 	lda extmsk ;extent mask to a
b6cd b6cd d a6
b6cd b6cd u 01 01
b6cd b6cd s 	ana m ;fcb(extnum) and extmsk
b6ce b6ce d 32e2bf
b6ce b6ce u 03 01
b6ce b6ce s 	sta extval
b6d1 b6d1 d c9
b6d1 b6d1 u 01 01
b6d1 b6d1 s 	ret
b6d2 b6d2 s ;
b6d2 b6d2 s setfcb:
b6d2 b6d2 s 	;place values back into current fcb
b6d2 b6d2 d cdaeb6
b6d2 b6d2 u 03 01
b6d2 b6d2 s 	call getfcba ;addresses to DE, HL
b6d5 b6d5 d 3ad5bf
b6d5 b6d5 u 03 01
b6d5 b6d5 s 	lda seqio
b6d8 b6d8 d fe02
b6d8 b6d8 u 02 01
b6d8 b6d8 s 	cpi 02!
b6da b6da d c2deb6
b6da b6da u 03 01
b6da b6da s  jnz setfcb1!
b6dd b6dd d af
b6dd b6dd u 01 01
b6dd b6dd s  xra a	;check ranfill	
b6de b6de s setfcb1:
b6de b6de d 4f
b6de b6de u 01 01
b6de b6de s  	mov c,a ;=1 if sequential i/o
b6df b6df d 3ae3bf
b6df b6df u 03 01
b6df b6df s 	lda vrecord!
b6e2 b6e2 d 81
b6e2 b6e2 u 01 01
b6e2 b6e2 s  add c!
b6e3 b6e3 d 77
b6e3 b6e3 u 01 01
b6e3 b6e3 s  mov m,a ;fcb(nxtrec)=vrecord+seqio
b6e4 b6e4 d eb
b6e4 b6e4 u 01 01
b6e4 b6e4 s 	xchg!
b6e5 b6e5 d 3ae1bf
b6e5 b6e5 u 03 01
b6e5 b6e5 s  lda rcount!
b6e8 b6e8 d 77
b6e8 b6e8 u 01 01
b6e8 b6e8 s  mov m,a ;fcb(reccnt)=rcount
b6e9 b6e9 d c9
b6e9 b6e9 u 01 01
b6e9 b6e9 s 	ret
b6ea b6ea s ;
b6ea b6ea s hlrotr:
b6ea b6ea s 	;hl rotate right by amount C
b6ea b6ea d 0c
b6ea b6ea u 01 01
b6ea b6ea s 	inr c ;in case zero
b6eb b6eb d 0d
b6eb b6eb u 01 01
b6eb b6eb s 	hlrotr0: dcr c!
b6ec b6ec d c8
b6ec b6ec u 01 01
b6ec b6ec s  rz ;return when zero
b6ed b6ed d 7c
b6ed b6ed u 01 01
b6ed b6ed s 		mov a,h!
b6ee b6ee d b7
b6ee b6ee u 01 01
b6ee b6ee s  ora a!
b6ef b6ef d 1f
b6ef b6ef u 01 01
b6ef b6ef s  rar!
b6f0 b6f0 d 67
b6f0 b6f0 u 01 01
b6f0 b6f0 s  mov h,a ;high byte
b6f1 b6f1 d 7d
b6f1 b6f1 u 01 01
b6f1 b6f1 s 		mov a,l!
b6f2 b6f2 d 1f
b6f2 b6f2 u 01 01
b6f2 b6f2 s  rar!
b6f3 b6f3 d 6f
b6f3 b6f3 u 01 01
b6f3 b6f3 s  mov l,a ;low byte
b6f4 b6f4 d c3ebb6
b6f4 b6f4 u 03 01
b6f4 b6f4 s 		jmp hlrotr0
b6f7 b6f7 s ;
b6f7 b6f7 s ;
b6f7 b6f7 s compute$cs:
b6f7 b6f7 s 	;compute checksum for current directory buffer
b6f7 b6f7 d 0e80
b6f7 b6f7 u 02 01
b6f7 b6f7 s 	mvi c,recsiz ;size of directory buffer
b6f9 b6f9 d 2ab9bf
b6f9 b6f9 u 03 01
b6f9 b6f9 s 	lhld buffa ;current directory buffer
b6fc b6fc d af
b6fc b6fc u 01 01
b6fc b6fc s 	xra a ;clear checksum value
b6fd b6fd s 	computecs0:
b6fd b6fd d 86
b6fd b6fd u 01 01
b6fd b6fd s 		add m!
b6fe b6fe d 23
b6fe b6fe u 01 01
b6fe b6fe s  inx h!
b6ff b6ff d 0d
b6ff b6ff u 01 01
b6ff b6ff s  dcr c ;cs=cs+buff(recsiz-C)
b700 b700 d c2fdb6
b700 b700 u 03 01
b700 b700 s 		jnz computecs0
b703 b703 d c9
b703 b703 u 01 01
b703 b703 s 	ret ;with checksum in A
b704 b704 s ;
b704 b704 s hlrotl:
b704 b704 s 	;rotate the mask in HL by amount in C
b704 b704 d 0c
b704 b704 u 01 01
b704 b704 s 	inr c ;may be zero
b705 b705 d 0d
b705 b705 u 01 01
b705 b705 s 	hlrotl0: dcr c!
b706 b706 d c8
b706 b706 u 01 01
b706 b706 s  rz ;return if zero
b707 b707 d 29
b707 b707 u 01 01
