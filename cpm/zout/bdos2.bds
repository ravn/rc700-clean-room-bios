bfb3 bfb3 s cdrmaxa:ds	word	;pointer to cur dir max value
bfb5 bfb5 s curtrka:ds	word	;current track address
bfb7 bfb7 s curreca:ds	word	;current record address
bfb9 bfb9 s buffa:	ds	word	;pointer to directory dma address
bfbb bfbb s dpbaddr:ds	word	;current disk parameter block address
bfbd bfbd s checka:	ds	word	;current checksum vector address
bfbf bfbf s alloca:	ds	word	;current allocation vector address
