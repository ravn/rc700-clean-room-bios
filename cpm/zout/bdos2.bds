b713 b713 d cd04b7
b713 b713 u 03 01
b713 b713 s 	call hlrotl ;HL = mask to integrate
b716 b716 d c1
b716 b716 u 01 01
b716 b716 s 	pop b ;original mask
b717 b717 d 79
b717 b717 u 01 01
b717 b717 s 	mov a,c!
b718 b718 d b5
b718 b718 u 01 01
b718 b718 s  ora l!
b719 b719 d 6f
b719 b719 u 01 01
b719 b719 s  mov l,a
b71a b71a d 78
b71a b71a u 01 01
b71a b71a s 	mov a,b!
b71b b71b d b4
b71b b71b u 01 01
b71b b71b s  ora h!
b71c b71c d 67
b71c b71c u 01 01
b71c b71c s  mov h,a ;HL = mask or rol(1,curdsk)
b71d b71d d c9
b71d b71d u 01 01
b71d b71d s 	ret
b71e b71e s ;
b71e b71e s nowrite:
b71e b71e s 	;return true if dir checksum difference occurred
b71e b71e d 2aadbf
b71e b71e u 03 01
b71e b71e s 	lhld rodsk!
b721 b721 d 3a42b5
b721 b721 u 03 01
b721 b721 s  lda curdsk!
b724 b724 d 4f
b724 b724 u 01 01
b724 b724 s  mov c,a!
b725 b725 d cdeab6
b725 b725 u 03 01
b725 b725 s  call hlrotr
b728 b728 d 7d
b728 b728 u 01 01
b728 b728 s 	mov a,l!
b729 b729 d e601
b729 b729 u 02 01
