b964 b964 s 			;not the ubytes field, extent field?
b964 b964 d fe0c
b964 b964 u 02 01
b964 b964 s 			cpi extnum ;may be extent field
b966 b966 d 1a
b966 b966 u 01 01
b966 b966 s 			ldax d ;fcb character
b967 b967 d ca73b9
b967 b967 u 03 01
b967 b967 s 			jz searchext ;skip to search extent
b96a b96a d 96
b96a b96a u 01 01
b96a b96a s 			sub m!
b96b b96b d e67f
b96b b96b u 02 01
b96b b96b s  ani 7fh ;mask-out flags/extent modulus
b96d b96d d c22db9
b96d b96d u 03 01
b96d b96d s 			jnz searchn ;skip if not matched
b970 b970 d c37cb9
b970 b970 u 03 01
b970 b970 s 			jmp searchok ;matched character
b973 b973 s 		searchext:
b973 b973 s 			;A has fcb character
b973 b973 s 			;attempt an extent # match
b973 b973 d c5
b973 b973 u 01 01
