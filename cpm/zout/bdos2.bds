bfdf bfdf s olddsk:	ds	byte	;disk on entry to bdos
bfe0 bfe0 s fcbdsk:	ds	byte	;disk named in fcb
bfe1 bfe1 s rcount:	ds	byte	;record count in current fcb
bfe2 bfe2 s extval:	ds	byte	;extent number and extmsk
bfe3 bfe3 s vrecord:ds	word	;current virtual record
bfe5 bfe5 s arecord:ds	word	;current actual record
bfe7 bfe7 s arecord1:	ds	word	;current actual block# * blkmsk
bfe9 bfe9 s ;
